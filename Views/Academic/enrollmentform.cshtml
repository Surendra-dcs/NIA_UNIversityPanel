@{
    ViewData["Title"] = "Enrollment Form";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />
<style>
    .student-container {
        font-family: Arial, sans-serif;
        padding: 15px;
    }

    .student-header {
        text-align: center;
        margin-bottom: 20px;
    }

        .student-header h2 {
            margin: 0;
            color: #2c3e50;
        }

        .student-header p {
            margin: 5px 0 0;
            color: #7f8c8d;
        }

    .student-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
    }

    .card {
        background: #ffffff;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }

        .card h3 {
            margin-top: 0;
            margin-bottom: 10px;
            color: #34495e;
            border-bottom: 1px solid #eee;
            padding-bottom: 5px;
        }

        .card p {
            margin: 6px 0;
            font-size: 14px;
            color: #555;
        }

        .card b {
            color: #222;
        }

    .modal-box {
        background: #fff;
        width: 850px;
        border-radius: 14px;
        box-shadow: 0 10px 35px rgba(0,0,0,0.15);
        animation: fadeIn 0.25s ease;
        overflow: hidden;
    }

    .image-modal {
        display: none;
        position: fixed;
        z-index: 99999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.95);
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .modal-content {
        max-width: 95vw;
        max-height: 95vh;
        width: auto;
        height: auto;
        object-fit: contain;
        transition: transform 0.3s ease;
        border-radius: 10px;
        background: white;
    }
   
    .preview-img {
        height: 150px;
        width: 150px;
        border: 1px solid #ccc;
        padding: 5px;
        cursor: pointer;
        object-fit: cover;
        border-radius: 5px;
    }

    .close-btn {
        position: absolute;
        top: 15px;
        right: 30px;
        color: white;
        font-size: 45px;
        cursor: pointer;
        z-index: 100000;
    }


    /* Rotate Button */
    .rotate-btn {
        position: absolute;
        top: 20px;
        left: 30px;
        padding: 10px 20px;
        border: none;
        background: #007bff;
        color: white;
        cursor: pointer;
        border-radius: 5px;
        font-size: 16px;
        z-index: 100000;
    }
    .search-panel {
        background: #fff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,.15);
    }

    .panel-title {
        margin-bottom: 20px;
        font-weight: 600;
        font-size: 19px;
    }

    .search-row {
        display: flex;
        align-items: end;
        gap: 15px;
        flex-wrap: wrap;
    }

    .search-group {
        display: flex;
        flex-direction: column;
    }

        .search-group label {
            font-weight: 600;
            margin-bottom: 5px;
        }

        .search-group select {
            width: 220px;
            height: 38px;
            border: 1px solid #ccc;
            border-radius: 5px;
            padding: 0 10px;
        }

    .search-btn {
        margin-top: 22px;
    }

        .search-btn button {
            height: 38px;
            padding: 0 25px;
            border: none;
            background: #0d6efd;
            color: #fff;
            border-radius: 5px;
            cursor: pointer;
        }

    .bottom-row {
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
        align-items: end;
        flex-wrap: wrap;
    }

    #bulkVerifyBtn {
        height: 40px;
        padding: 0 25px;
        background: #28a745;
        color: #fff;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }
</style>

<div class="search-panel">
    <h5 class="panel-title">Student Enrollment Form Verification</h5>
    <div class="search-row">
        <div class="search-group">
            <label>Session</label>
            <select id="sessionId">
                <option>Select Session</option>
            </select>
        </div>

        <div class="search-group">
            <label>Program</label>
            <select id="programId">
                <option>Select Program</option>
            </select>
        </div>

        <div class="search-group">
            <label>Course</label>
            <select id="courseId">
                <option>Select Course</option>
            </select>
        </div>

        <div class="search-group">
            <label>Semester</label>
            <select id="semester">
                <option>Select Semester</option>
            </select>
        </div>

        <div class="search-btn">
            <button onclick="loadStudentEnrollmentList()">
                Filter
            </button>
        </div>
    </div>

    <div class="bottom-row">
        <div class="search-group">
            <label>Sort By</label>
            <select id="sortOrder">
                <option>-- Sort By --</option>
                <option value="asc">Ascending</option>
                <option value="desc">Descending</option>
            </select>
        </div>

        <button id="bulkVerifyBtn">
            Bulk Verify
        </button>
        <button class="btn btn-primary" id="exportExcelBtn" style="background: #1a3a5c;color: white;">
            Export Excel
        </button>
    </div>
</div>

<div class="table-card">
    <div class="table-header">
        <h3 class="table-title">Student Enrollment Form</h3>
    </div>
    <div class="table-responsive">
        <table id="studentEnrollmenttbl" class="display custom-table">
            <thead>
                <tr>
                    <th style="width:57px;text-align:center">
                        Select<br />
                        <input type="checkbox" id="selectAll">
                    </th>
                    <th>Sr.No.</th>                   
                    <th>Enrollment Number</th>
                    <th>College</th>
                    <th>Program</th>
                    <th>Course</th>
                    <th>Student Name</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>View</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Student Details Modal -->
<div id="studentModal" class="modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Student Details</h3>
            <span class="close-btn" onclick="closeStudentModal()">&times;</span>
        </div>
        <div class="modal-body" id="studentDetails"></div>
        <div class="modal-footer">
            <button class="btn btn-cancel" onclick="closeStudentModal()">Close</button>
        </div>
    </div>
</div>
<div id="imageModal" class="image-modal" style="display:none;">
    <span class="close-btn" onclick="closeImage()">&times;</span>
    <button class="rotate-btn" onclick="rotateImage()">
        Rotate
    </button>
    <img class="modal-content" id="popupImage">
</div>
<!-- Include the shared admit card JS -->
<script src="~/js/enrollmentAdmitCard.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>

    let table;
    let allData = [];
    $(document).ready(function () {
    loadPrograms();
    loadSession();
    $('#selectAll').on('change', function () {
            $('.rowCheckbox:not(:disabled)').prop(
                'checked',
                $(this).prop('checked')
            );

        });
    });
    function loadSession() {
        $.get(ApiBaseUrl + 'Course/GetSession', function (res) {
            let session = '<option value="">Select Session</option>';
            res.forEach(x => {
                session += `<option value="${x.sessionId}">${x.sessionName}</option>`;
            });
            $('#sessionId').html(session);
        });
    }
    function loadPrograms() {
        $.get(ApiBaseUrl + 'Course/GetPrograms', function (res) {
            let opt = '<option value="">Select Program</option>';
            res.forEach(x => {
                opt += `<option value="${x.programId}">${x.programName}</option>`;
            });
            $('#programId').html(opt);
        });
    }

    document.getElementById("programId").addEventListener("change", function () {
        let programId = this.value;
        $("#courseId").val('');
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/courses/${programId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("courseId");
                courseDropdown.innerHTML = '<option value="">Select Course</option>';
                data.forEach(item => {
                     courseDropdown.innerHTML += `<option value="${item.course_Id}">${item.course_Name}</option>`;
                });
            });
     });
    document.getElementById("courseId").addEventListener("change", function () {
        let courseId = this.value;
        $("#semester").val('');
        fetch(ApiBaseUrl + `Subject/semester/${courseId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("semester");
                courseDropdown.innerHTML = '<option value="">Select Semester</option>';
                data.forEach(item => {
                     courseDropdown.innerHTML += `<option value="${item.semesterId}">${item.semesterName}</option>`;
                });
            });
     });

    function loadStudentEnrollmentList() {
      
        if ($.fn.DataTable.isDataTable('#studentEnrollmenttbl')) {
            $('#studentEnrollmenttbl').DataTable().destroy();
            $('#studentEnrollmenttbl tbody').empty();
        }
        let sessionId = $("#sessionId").val();
        let courseId = $("#courseId").val();
        let semester = $("#semester").val();
        table = $('#studentEnrollmenttbl').DataTable({
            processing: true,
            destroy: true,
            responsive: true,
            ajax: {
                url: ApiBaseUrl + `StudentEnrollment/GetStudentEnrollmentList?sessionId=${sessionId}&courseId=${courseId}&semester=${semester}`,
                type: 'POST',
                dataSrc: function (json) {
                    allData = json;
                    return json;
                }
            },
            columns: [
                {
                    data: null,
                    orderable: false,
                    render: function (data) {
                        if (data.isVerify) {
                            return '';
                        }
                        return `
                            <div class="text-center">
                                <input type="checkbox"
                                       class="rowCheckbox"
                                       value="${data.id}">
                            </div>
                        `;
                    }
                },

                {
                    data: null,
                    render: function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },

                { data: 'enrollmentNumber', defaultContent: '-' },
                { data: 'collegeName', defaultContent: '-' },
                { data: 'programName', defaultContent: '-' },
                { data: 'courseName', defaultContent: '-' },
                { data: 'studentName', defaultContent: '-' },
                { data: 'email', defaultContent: '-' },
                { data: 'mobile', defaultContent: '-' },

                {
                    data: null,
                    orderable: false,
                    render: function (data) {

                        return `
                            <button class="btn btn-sm"
                                    style="background:#05960a;color:#fff;"
                                    onclick='viewStudent(${JSON.stringify(data)})'>
                                View
                            </button>
                        `;
                    }
                },

                {
                    data: null,
                    orderable: false,
                    render: function (data) {

                        let isVerified = data.isVerify;

                        return `
                            <button class="btn btn-sm ms-1"
                                    style="background:#b99e11;color:#fff;"
                                    onclick='printEnrollment(${JSON.stringify(data)})'>
                                Print
                            </button>

                            <button class="btn btn-sm ms-1"
                                    style="${isVerified
                                        ? 'background:gray;color:white;opacity:.6;cursor:not-allowed;'
                                        : 'background:#2d7dd2;color:white;'}"
                                    onclick="verifyForm(${data.id})"
                                    ${isVerified ? 'disabled' : ''}>
                                ${isVerified ? 'Verified' : 'Verify'}
                            </button>
                        `;
                    }
                }

            ]

        });
    }

    function verifyForm(id) {
        if (!confirm("Are you sure you want to verify this student?"))
            return;

        $.ajax({
            url: ApiBaseUrl + 'StudentEnrollment/VerifyStudent',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ id: id }),
            success: function () {
                alert("Student verified successfully");
                table.ajax.reload();
            },
            error: function () {
                alert("Verification failed");
            }
        });
    }

    function closeStudentModal() {
        $('#studentModal').hide();
    }

    $('#sortOrder').change(function () {
        var val = $(this).val();

        if (val === "asc") {
            table.order([5, 'asc']).draw();
        } else if (val === "desc") {
            table.order([5, 'desc']).draw();
        }
    });

    $('#btnBulkGenerate').click(function () {
        if (!confirm("Generate enrollment numbers for all pending records?"))
            return;

        $.post(ApiBaseUrl+'StudentEnrollment/generate-bulk', function (res) {
            alert(res.message);
            $('#studentEnrollmenttbl').DataTable().ajax.reload();
        });
    });

    $(document).on('change', '#selectAll', function () {
        $('.rowCheckbox').prop('checked', $(this).prop('checked'));
    });

    $('#bulkVerifyBtn').click(function () {
        let ids = [];
        $('.rowCheckbox:checked').each(function () {
            ids.push(parseInt($(this).val()));
        });
        if (ids.length === 0) {
            alert('Please select at least one student');
            return;
        }
        $.ajax({
            url: ApiBaseUrl + 'StudentEnrollment/BulkVerify',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(ids),
            success: function () {
                alert('Students verified successfully');
                table.ajax.reload();
            },
            error: function () {
                alert('Bulk verify failed');
            }
        });
    });


    function openStudentModal() {
        $('#studentModal').css('display', 'flex');
    }

    function closeStudentModal() {
        $('#studentModal').hide();
    }

    function viewStudent(data) {

        let html = `
        <div class="student-container">

            <div class="student-header">
                <h2>${data.studentName}</h2>
                <p>${data.programName} - ${data.courseName}</p>
            </div>

            <div class="student-grid" style="overflow-y:scroll;height:440px">

                <div class="card">
                    <h3>Personal Details</h3>
                    <p><b>Father:</b> ${data.fatherName}</p>
                    <p><b>Mother:</b> ${data.motherName || '-'}</p>
                    <p><b>Gender:</b> ${data.gender}</p>
                    <p><b>DOB:</b> ${new Date(data.dateOfBirth).toLocaleDateString()}</p>
                    <p><b>Category:</b> ${data.category}</p>
                    <p><b>Religion:</b> ${data.religion}</p>
                    <p><b>Nationality:</b> ${data.nationality}</p>
                </div>

                <div class="card">
                    <h3>Contact Details</h3>
                    <p><b>Mobile:</b> ${data.mobile}</p>
                    <p><b>Email:</b> ${data.email}</p>
                    <p><b>Address:</b> ${data.addressLine1}</p>
                    <p><b>City:</b> ${data.city}</p>
                    <p><b>District:</b> ${data.district}</p>
                    <p><b>State:</b> ${data.state}</p>
                    <p><b>PIN:</b> ${data.pinCode}</p>
                    <p><b>Country:</b> ${data.country}</p>
                </div>

                <div class="card">
                    <h3>Academic Details</h3>
                    <p><b>College:</b> ${data.collegeName}</p>
                    <p><b>Program:</b> ${data.programName}</p>
                    <p><b>Course:</b> ${data.courseName}</p>
                </div>

                <div class="card">
                <h3>Identification</h3>
               ${
                   data.nationality === 'Foreign'
                       ? `
                           <p><b>Passport Number:</b> ${data.passportNumber ?? ''}</p>
                         `
                       : `
                           <p><b>Aadhaar:</b> ${data.aadhaarNumber ?? ''}</p>
                           <p><b>ABC ID:</b> ${data.abcId ?? ''}</p>
                         `
               }
              </div>
              <div class="card" style="display:flex; gap:20px; align-items:center;width:354px;">
                  <span>
                      <img src="${data.candidateImagePath}" class="preview-img"  onclick="openImage(this.src)"  alt="Candidate Image">
                  </span>
                  <span>
                      <img src="${data.signatureImagePath}"  class="preview-img"  onclick="openImage(this.src)" alt="Signature Image">
                  </span>              
              </div>

                <div class="card" style="display:flex; gap:20px; align-items:center; flex-wrap:wrap; width:100%;">
                   ${
                   data.nationality === 'Foreign'
                   ?
                       renderDocument(data.passportImagePath, "Passport") +
                       renderDocument(data.marksheetImagePath, "Marksheet")
                   :
                       renderDocument(data.aadhaarFrontImagePath, "Aadhaar Front") +
                       renderDocument(data.aadhaarBackImagePath, "Aadhaar Back") +
                       renderDocument(data.marksheetImagePath, "Marksheet")
                  }
               </div>

            </div>
        </div>
        `;

        document.getElementById('studentDetails').innerHTML = html;
        openStudentModal();
    }

    $(window).on('click', function (e) {
        if ($(e.target).is('#studentModal')) {
            closeStudentModal();
        }
    });
        function renderDocument(path, alt) {
        if (!path) {
            return `
                <div class="doc-item">
                    <span>No Document</span>
                </div>`;
        }

        let ext = path.split('.').pop().toLowerCase();
        if (ext === "pdf") {
            return `
                <div class="doc-item">
                    <embed src="${path}"
                           type="application/pdf"
                           class="preview-pdf"
                           onclick="window.open('${path}','_blank')">

                    <div class="doc-title">${alt}</div>
                </div>`;
        }
        return `
            <div class="doc-item">
                <img src="${path}"
                     class="preview-img"
                     onclick="openImage(this.src)"
                     alt="${alt}">
                <div class="doc-title">${alt}</div>
            </div>`;
    }

     function closeImage() {
        $('#imageModal').fadeOut();
    }
    let currentRotation = 0;
    function openImage(src) {
        currentRotation = 0;
        $('#popupImage')
            .attr('src', src)
            .css({
                'transform': 'rotate(0deg)',
                'display': 'block'
            });
        $('#imageModal').css('display', 'flex');
    }
      function closeImage() {
        $('#imageModal').hide();
    }
   

    function rotateImage() {
        currentRotation += 90;
        $('#popupImage').css(
            'transform',
            `rotate(${currentRotation}deg)`
        );
    }
    $('#imageModal').click(function (e) {
        if (e.target.id === 'imageModal') {
            closeImage();
        }
    });

    $('#exportExcelBtn').click(function () {

        let exportData = allData.map((item, index) => {
            return {
                "Enrollment Number": item.enrollmentNumber,
                "College": item.collegeName,
                "Program": item.programName,
                "Course": item.courseName,
                "Student Name": item.studentName,
                "Email": item.email,
                "Mobile": item.mobile
            };
        });

        // Create worksheet
        let ws = XLSX.utils.json_to_sheet(exportData);

        // Create workbook
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Student Enrollment");

        // Download Excel
        XLSX.writeFile(wb, "StudentEnrollment.xlsx");
    });


</script>

