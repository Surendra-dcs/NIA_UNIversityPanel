
@{
    ViewData["Title"] = "ExamformVerification";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />
<style>
    .student-container {
        font-family: Arial, sans-serif;
        padding: 15px;
    }

    .student-header {
        text-align: center;
        margin-bottom: 20px;
    }

        .student-header h2 {
            margin: 0;
            color: #2c3e50;
        }

        .student-header p {
            margin: 5px 0 0;
            color: #7f8c8d;
        }

    .student-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
    }

    .card {
        background: #ffffff;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: 0.2s;
    }

        .card:hover {
            transform: translateY(-3px);
        }

        .card h3 {
            margin-top: 0;
            margin-bottom: 10px;
            color: #34495e;
            border-bottom: 1px solid #eee;
            padding-bottom: 5px;
        }

        .card p {
            margin: 6px 0;
            font-size: 14px;
            color: #555;
        }

        .card b {
            color: #222;
        }

    .modal-box {
        background: #fff;
        width: 850px;
        border-radius: 14px;
        box-shadow: 0 10px 35px rgba(0,0,0,0.15);
        animation: fadeIn 0.25s ease;
        overflow: hidden;
    }

    .image-modal {
        display: none;
        position: fixed;
        z-index: 99999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.95);
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .modal-content {
        max-width: 95vw;
        max-height: 95vh;
        width: auto;
        height: auto;
        object-fit: contain;
        transition: transform 0.3s ease;
        border-radius: 10px;
        background: white;
    }

    .preview-img {
        height: 150px;
        width: 150px;
        border: 1px solid #ccc;
        padding: 5px;
        cursor: pointer;
        object-fit: cover;
        border-radius: 5px;
    }

    .close-btn {
        position: absolute;
        top: 15px;
        right: 30px;
        color: white;
        font-size: 45px;
        cursor: pointer;
        z-index: 100000;
    }


    /* Rotate Button */
    .rotate-btn {
        position: absolute;
        top: 20px;
        left: 30px;
        padding: 10px 20px;
        border: none;
        background: #007bff;
        color: white;
        cursor: pointer;
        border-radius: 5px;
        font-size: 16px;
        z-index: 100000;
    }
</style>
<div style="display:flex; gap:10px; margin-bottom:10px;">
    <select id="sortOrder" class="form-control" style="width:200px;">
        <option value="">-- Sort By --</option>
        <option value="asc"> Ascending </option>
        <option value="desc"> Descending </option>
    </select>

    <button class="btn btn-success" id="bulkVerifyBtn" style="background:#89e7b5">
        Bulk Exam From Verify
    </button>
</div>
<div class="table-card">
    <div class="table-header">
        <h3 class="table-title">Exam Form Verification</h3>
    </div>
    <div class="table-responsive">
        <table id="studentformtbl" class="display custom-table">
            <thead>
                <tr>
                    <th style="width:57px;text-align:center">
                        Select<br />
                        <input type="checkbox" id="selectAll">
                    </th>
                    <th>Sr.No.</th>
                    <th>Roll Number</th>
                    <th>College</th>
                    <th>Program</th>
                    <th>Course</th>
                    <th>Student Name </th>
                    <th>Father Name </th>
                    <th>Mobile</th>
                    <th>View</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<div id="studentModal" class="modal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Student Details</h3>
            <span class="close-btn" onclick="closeStudentModal()">&times;</span>
        </div>
        <div class="modal-body" id="studentDetails"></div>
        <div class="modal-footer">
            <button class="btn btn-cancel" onclick="closeStudentModal()">Close</button>
        </div>
    </div>
</div>
<div id="imageModal" class="image-modal" style="display:none;">
    <span class="close-btn" onclick="closeImage()">&times;</span>
    <button class="rotate-btn" onclick="rotateImage()">
        Rotate
    </button>
    <img class="modal-content" id="popupImage">
</div>
<script>
    let table;
    let allData = [];
      $(document).ready(function () {
        table = $('#studentformtbl').DataTable({
            ajax: {
                url: ApiBaseUrl + 'StudentEnrollment/GetStudentformList',
                type: 'GET',
                dataSrc: function (json) {
                    allData = json;
                    return json;
                }
            },
            columns: [
                {
                    data: null,
                    render: function (data) {
                    if (data.isVerify) {
                    
                        return `
                            <div style="text-align:center;">
                                <input type="checkbox"
                                       class="rowCheckbox"
                                       value="${data.id}"
                                       checked
                                       disabled>
                            </div>
                        `;
                    }
        
                   return `
                       <div style="text-align:center;">
                           <input type="checkbox"
                                  class="rowCheckbox"
                                  value="${data.id}">
                       </div>
                   `;
                },
                    orderable: false
                },
                {
                    data: null,
                    render: function (data, type, row, meta) {
                        return meta.row + meta.settings._iDisplayStart + 1;
                    }
                },
                {
                    data: 'rollNumber',
                    defaultContent: '-'
                },
                {
                    data: 'collegeName',
                    defaultContent: '-'
                },
                {
                    data: 'programName',
                    defaultContent: '-'
                },
                {
                    data: 'courseName',
                    defaultContent: '-'
                },

                {
                    data: 'studentName',
                    defaultContent: '-'
                },
                {
                    data: 'fatherName',
                    defaultContent: '-'
                },
                {
                    data: 'mobile',
                    defaultContent: '-'
                },
                {
                    data: null,
                    render: function (data) {
                        return `
                            <button class="btn btn-sm"
                                    style="background:#05960a;color:white;"
                                    onclick="viewStudent(${data.id})">
                                View
                            </button>
                        `;
                    }
                },
                {
                    data: null,
                    render: function (data) {
                        let isVerified = data.isVerify;
                        let buttonText = isVerified
                            ? 'Verified'
                            : 'Verify';

                        let verifyDisabled = isVerified
                            ? 'disabled'
                            : '';

                        let verifyStyle = isVerified
                            ? 'background:gray;color:white;opacity:0.6;cursor:not-allowed;'
                            : 'background:#2d7dd2;color:white;';

                        return `
                            <button class="btn btn-sm"
                                    style="${verifyStyle}"
                                    onclick="verifyForm(${data.id})"
                                    ${verifyDisabled}>
                                ${buttonText}
                            </button>
                        `;
                    }
                }
            ]
        });
        $('#selectAll').on('change', function () {
            $('.rowCheckbox').prop(
                'checked',
                $(this).prop('checked')
            );
        });
    });
       function verifyForm(id) {
        let checkbox = $(`.rowCheckbox[value="${id}"]`);
        if (!checkbox.prop('checked')) {
            alert("Please select checkbox first");
            return;
        }
        if (!confirm("Are you sure you want to verify this student?"))
            return;
        $.ajax({
            url: ApiBaseUrl + 'StudentEnrollment/StudentformVerify',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ id: id }),
            success: function () {
                alert("Student verified successfully");
                table.ajax.reload();
            },
            error: function () {
                alert("Verification failed");

            }
        });
    }

    function closeStudentModal() {
        $('#studentModal').hide();
    }

    $('#sortOrder').change(function () {
        var val = $(this).val();

        if (val === "asc") {
            table.order([5, 'asc']).draw();
        } else if (val === "desc") {
            table.order([5, 'desc']).draw();
        }
    });
 

    $(document).on('change', '#selectAll', function () {
        $('.rowCheckbox').prop('checked', $(this).prop('checked'));
    });

    $('#bulkVerifyBtn').click(function () {
        let ids = [];
        $('.rowCheckbox:checked').each(function () {
            ids.push(parseInt($(this).val()));
        });
        if (ids.length === 0) {
            alert('Please select at least one student');
            return;
        }
        $.ajax({
            url: ApiBaseUrl + 'StudentEnrollment/BulkformVerify',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(ids),
            success: function () {
                alert('Students verified successfully');
                table.ajax.reload();
            },
            error: function () {
                alert('Bulk verify failed');
            }
        });
    });

    function openStudentModal() {
        $('#studentModal').css('display', 'flex');
    }

    function closeStudentModal() {
        $('#studentModal').hide();
    }
     function viewStudent(id) {
        let student = allData.find(x => x.id == id);
        if (!student) {
            alert("Student not found");
            return;
        }
        let subjectRows = '';
        if (student.subjects && student.subjects.length > 0) {
            student.subjects.forEach((s, index) => {
                subjectRows += `
                    <tr>
                        <td>${index + 1}</td>
                        <td>${s.subjectName || '-'}</td>
                        <td>${s.subjectCode || '-'}</td>                        
                    </tr>
                `;
            });

        } else {
            subjectRows = `
                <tr>
                    <td colspan="7" style="text-align:center;">
                        No Subject Found
                    </td>
                </tr>
            `;
        }

        let html = `

        <div class="student-container">
            <!-- HEADER -->
            <div class="student-header" style="margin-bottom:20px;">
                <h2 style="margin-bottom:5px;">
                    ${student.studentName || '-'}
                </h2>
                <p>
                    ${student.programName || '-'}
                    -
                    ${student.courseName || '-'}
                </p>

            </div>


            <div class="student-grid"
                 style="overflow-y:auto;
                        height:500px;
                        padding-right:10px;">


                <!-- PERSONAL DETAILS -->
                <div class="card" style="margin-bottom:20px;">

                    <h3>Personal Details</h3>

                    <p><b>Enrollment No :</b> ${student.enrollmentNumber || '-'}</p>

                    <p><b>Roll Number :</b> ${student.rollNumber || '-'}</p>

                    <p><b>Form Number :</b> ${student.formNumber || '-'}</p>

                    <p><b>Student Name :</b> ${student.studentName || '-'}</p>

                    <p><b>Father Name :</b> ${student.fatherName || '-'}</p>

                    <p><b>Mother Name :</b> ${student.motherName || '-'}</p>

                    <p><b>Gender :</b> ${student.gender || '-'}</p>

                    <p><b>DOB :</b> ${student.dateOfBirth || '-'}</p>

                    <p><b>Category :</b> ${student.category || '-'}</p>

                    <p><b>Mobile :</b> ${student.mobile || '-'}</p>

                    <p><b>Email :</b> ${student.email || '-'}</p>

                </div>


                <!-- ACADEMIC DETAILS -->
                <div class="card" style="margin-bottom:20px;">

                    <h3>Academic Details</h3>

                    <p><b>College :</b> ${student.collegeName || '-'}</p>

                    <p><b>Program :</b> ${student.programName || '-'}</p>

                    <p><b>Course :</b> ${student.courseName || '-'}</p>

                </div>


                <!-- IMAGES -->
                <div class="card"
                     style="margin-bottom:20px;">

                    <h3>Student Images</h3>

                    <div style="display:flex;
                                gap:20px;
                                align-items:center;
                                flex-wrap:wrap;">

                        <div>

                            <p style="margin-bottom:10px;">
                                <b>Photo</b>
                            </p>

                            <img src="${student.candidateImagePath || ''}"
                                 class="preview-img"
                                 onclick="openImage(this.src)"
                                 alt="Candidate Image"
                                 style="width:140px;
                                        height:160px;
                                        object-fit:cover;
                                        border:1px solid #ddd;
                                        border-radius:8px;">

                        </div>

                        <div>

                            <p style="margin-bottom:10px;">
                                <b>Signature</b>
                            </p>

                            <img src="${student.signatureImagePath || ''}"
                                 class="preview-img"
                                 onclick="openImage(this.src)"
                                 alt="Signature Image"
                                 style="width:180px;
                                        height:80px;
                                        object-fit:contain;
                                        border:1px solid #ddd;
                                        border-radius:8px;
                                        background:#fff;">

                        </div>

                    </div>

                </div>


                <!-- SUBJECT DETAILS FULL WIDTH -->
                <div class="card"
                     style="margin-top:20px;
                            width:100%;">

                    <h3 style="margin-bottom:15px;">
                        Subject Details
                    </h3>
                    <div style="overflow-x:auto;">
                        <table class="table table-bordered"
                               style="width:100%;
                                      border-collapse:collapse;">

                            <thead style="background:#2d7dd2;
                                           color:white;">
                                <tr>
                                    <th>Sr.No</th>
                                    <th>Subject Name</th>
                                    <th>Subject Code</th>   
                                </tr>
                            </thead>
                            <tbody>
                                ${subjectRows}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        `;

    $('#studentDetails').html(html);
        openStudentModal();
    }
    $(window).on('click', function (e) {
        if ($(e.target).is('#studentModal')) {
            closeStudentModal();
        }
    });
    function closeImage() {
    $('#imageModal').fadeOut();
    }
    let currentRotation = 0;
    function openImage(src) {
        currentRotation = 0;
        $('#popupImage')
            .attr('src', src)
            .css({
                'transform': 'rotate(0deg)',
                'display': 'block'
            });
        $('#imageModal').css('display', 'flex');
    }
    function closeImage() {
        $('#imageModal').hide();
    }
    function rotateImage() {
        currentRotation += 90;
        $('#popupImage').css(
            'transform',
            `rotate(${currentRotation}deg)`
        );
    }
    $('#imageModal').click(function (e) {
        if (e.target.id === 'imageModal') {
            closeImage();
        }
    });
</script>




