@{
    Layout = null;
    ViewBag.Title = "Login";
    var mobile = ViewBag.Mobile as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – NIA Online Examination Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Noto+Sans+Devanagari:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'DM Sans', 'Noto Sans Devanagari', system-ui, sans-serif;
        }

        .hindi, [lang="hi"] {
            font-family: 'Noto Sans Devanagari', 'DM Sans', sans-serif;
        }

        html, body {
            margin: 0;
            padding: 0;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideLeft {
            from {
                opacity: 0;
                transform: translateX(-32px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes slideRight {
            from {
                opacity: 0;
                transform: translateX(32px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes pulse-ring {
            0% {
                box-shadow: 0 0 0 0 rgba(5,150,105,0.35);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(5,150,105,0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(5,150,105,0);
            }
        }

        .fade-up {
            animation: fadeUp 0.6s ease both;
        }

        .slide-left {
            animation: slideLeft 0.65s ease both;
        }

        .slide-right {
            animation: slideRight 0.65s ease both;
        }

        /* OTP input special styling */
        .otp-input {
            letter-spacing: 0.45em;
            font-size: 1.35rem;
            font-weight: 600;
            text-align: center;
        }

        /* Form inputs */
        .nia-input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid #d1d5db;
            border-radius: 0.625rem;
            font-size: 0.95rem;
            color: #1e293b;
            background: #f9fafb;
            transition: all 0.2s ease;
            outline: none;
        }

            .nia-input::placeholder {
                color: #9ca3af;
            }

            .nia-input:focus {
                border-color: #059669;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(5,150,105,0.12);
            }

        /* Primary button */
        .nia-btn {
            width: 100%;
            padding: 0.8rem 1.5rem;
            background: linear-gradient(135deg, #059669, #0d9488);
            color: #fff;
            font-weight: 600;
            font-size: 0.95rem;
            border: none;
            border-radius: 0.625rem;
            cursor: pointer;
            transition: all 0.22s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            letter-spacing: 0.01em;
        }

            .nia-btn:hover:not(:disabled) {
                transform: translateY(-2px);
                box-shadow: 0 8px 22px rgba(5,150,105,0.32);
            }

            .nia-btn:active:not(:disabled) {
                transform: translateY(0);
            }

            .nia-btn:disabled {
                opacity: 0.65;
                cursor: not-allowed;
            }

        /* Alert */
        .alert-box {
            display: none;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            margin-bottom: 1.1rem;
            animation: fadeUp 0.3s ease both;
        }

        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
            border-left: 4px solid #dc2626;
        }

        .alert-success {
            background: #dcfce7;
            color: #166534;
            border-left: 4px solid #22c55e;
        }

        .alert-warning {
            background: #fef9c3;
            color: #854d0e;
            border-left: 4px solid #fbbf24;
        }

        /* Gradient border card */
        .gradient-border-card {
            position: relative;
            background: white;
            border-radius: 1.25rem;
        }

            .gradient-border-card::before {
                content: '';
                position: absolute;
                inset: -1.5px;
                border-radius: 1.35rem;
                background: linear-gradient(135deg, #059669, #0d9488, #14b8a6);
                mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
                pointer-events: none;
            }

        /* Spinner */
        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .spinner {
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255,255,255,0.4);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: none;
        }

            .spinner.active {
                display: inline-block;
            }

        /* Step indicator */
        .step-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,0.22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.78rem;
            font-weight: 700;
            flex-shrink: 0;
        }

            .step-dot.done {
                background: rgba(255,255,255,0.85);
                color: #065f46;
            }

        ::-webkit-scrollbar {
            width: 5px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }

        ::-webkit-scrollbar-thumb {
            background: #059669;
            border-radius: 4px;
        }

        /* only-number JS class helper */
        input.onlyNumber {
            -moz-appearance: textfield;
        }

            input.onlyNumber::-webkit-outer-spin-button,
            input.onlyNumber::-webkit-inner-spin-button {
                -webkit-appearance: none;
            }
    </style>
</head>
<body class="min-h-screen" style="background: linear-gradient(135deg, #ecfdf5 0%, #f0fdfa 50%, #f8fafc 100%);">

    <!-- ─── Header ─────────────────────────────────────────────────────────────── -->
    <header class="bg-white/95 backdrop-blur-md shadow-sm border-b border-emerald-100 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-5 sm:px-8 py-3.5">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 sm:w-16 sm:h-16 bg-gradient-to-br from-emerald-50 to-white rounded-xl shadow border border-emerald-100 flex items-center justify-center p-1.5">
                        <img src="~/Logo/nia_logo.png" asp-append-version="true" alt="NIA Logo" class="w-full h-full object-contain" />
                    </div>
                    <div>
                        <h1 class="hindi text-lg sm:text-xl font-bold" style="background:linear-gradient(90deg,#065f46,#0f766e);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
                            राष्ट्रीय आयुर्वेद संस्थान
                        </h1>
                        <p class="hindi text-[11px] text-slate-500 leading-tight">मानद विश्वविद्यालय (डी. नोवो) | आयुष मंत्रालय, भारत सरकार</p>
                        <p class="text-[10px] font-semibold text-emerald-700 tracking-wide uppercase mt-0.5">National Institute of Ayurveda (Deemed to be University)</p>
                    </div>
                </div>
                <div class="hidden sm:flex items-center gap-2 bg-emerald-50 border border-emerald-200 px-4 py-2 rounded-full">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-xs font-medium text-emerald-700">Secure Login</span>
                </div>
            </div>
        </div>
    </header>

    <!-- ─── Main ───────────────────────────────────────────────────────────────── -->
    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
        <div class="flex flex-col lg:flex-row items-stretch gap-6 lg:gap-8">

            <!-- ── Left Panel ─────────────────────────────────────────────── -->
            <div class="slide-left lg:w-5/12 rounded-2xl shadow-2xl overflow-hidden"
                 style="background: linear-gradient(145deg, #065f46, #0f766e 60%, #047857);">
                <div class="p-8 text-white h-full flex flex-col">
                    <!-- Badge -->
                    <div class="inline-flex items-center gap-2 self-start bg-white/20 backdrop-blur-sm rounded-full px-3.5 py-1.5 mb-6">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-xs font-semibold tracking-wide">Important Information</span>
                    </div>

                    <h2 class="text-2xl font-bold mb-1">University Login</h2>
                    <p class="text-emerald-200 text-sm mb-8">Please read carefully before proceeding</p>

                    <div class="space-y-5 flex-1">
                        <div class="flex gap-3 items-start">
                            <div class="step-dot @(mobile != null ? "done" : "")">1</div>
                            <div>
                                <p class="text-sm font-semibold mb-0.5">Enter Mobile Number</p>
                                <p class="text-xs text-emerald-200 leading-relaxed">Enter your registered mobile number to receive a One-Time Password.</p>
                            </div>
                        </div>
                        <div class="w-px h-4 bg-white/20 ml-3.5"></div>
                        <div class="flex gap-3 items-start">
                            <div class="step-dot @(mobile != null ? "done" : "")">2</div>
                            <div>
                                <p class="text-sm font-semibold mb-0.5">Verify with OTP</p>
                                <p class="text-xs text-emerald-200 leading-relaxed">Enter the 6-digit OTP sent to your mobile to complete login.</p>
                            </div>
                        </div>
                        <div class="w-px h-4 bg-white/20 ml-3.5"></div>
                        <div class="flex gap-3 items-start">
                            <div class="step-dot">3</div>
                            <div>
                                <p class="text-sm font-semibold mb-0.5">Access Dashboard</p>
                                <p class="text-xs text-emerald-200 leading-relaxed">Access the examination portal and manage all operations.</p>
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 pt-5 border-t border-white/20 space-y-3">                        
                        <div class="flex items-center gap-2 text-xs text-emerald-200">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            <span>Never share your OTP with anyone.</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Right Panel – Login Form ───────────────────────────────── -->
            <div class="slide-right flex-1">
                <div class="gradient-border-card shadow-2xl">
                    <div class="p-8 sm:p-10">

                        <!-- Icon & title -->
                        <div class="text-center mb-8 fade-up">
                            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-4"
                                 style="background:linear-gradient(135deg,#d1fae5,#ccfbf1);">
                                <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8"
                                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                </svg>
                            </div>
                            <h2 class="text-2xl font-bold text-slate-800">WELCOME</h2>
                            <p class="hindi text-sm text-slate-500 mt-1">विश्वविद्यालय लॉगिन / UNIVERSITY LOGIN</p>
                            <p class="text-xs text-slate-400 mt-1.5">LOGIN TO ACCESS YOUR UNIVERSITY DASHBOARD</p>
                        </div>

                        <!-- Alert Box -->
                        <div id="alertBox" class="alert-box"></div>

                        <!-- Server-side error (Razor) -->
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert-box alert-danger" style="display:block;">
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    @ViewBag.Error
                                </div>
                            </div>
                        }

                        <!-- ── STEP 1: Mobile Number ── -->
                        @if (mobile == null)
                        {
                            <form method="post" asp-action="Login" asp-controller="Account" id="mobileForm">
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-2">
                                        Mobile Number
                                    </label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                                            <svg class="w-4.5 h-4.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                            </svg>
                                        </div>
                                        <input type="tel"
                                               name="mobile"
                                               id="mobileInput"
                                               class="nia-input onlyNumber pl-10"
                                               maxlength="10"
                                               placeholder="Enter 10-digit mobile number"
                                               pattern="[6-9][0-9]{9}"
                                               required />
                                    </div>
                                    <p class="text-xs text-slate-400 mt-1.5 ml-1">Enter the mobile number registered with NIA.</p>
                                </div>

                                <button type="submit" id="sendOtpBtn" class="nia-btn">
                                    <div class="spinner" id="sendSpinner"></div>
                                    <svg id="sendIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                                    </svg>
                                    <span id="sendText">Send OTP</span>
                                </button>
                            </form>
                        }

                        <!-- ── STEP 2: OTP Verification ── -->
                        @if (mobile != null)
                        {
                            <!-- Step indicator banner -->
                            <div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 rounded-xl p-3.5 mb-6">
                                <div class="w-9 h-9 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                                    <svg class="w-4.5 h-4.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-emerald-800">OTP Sent Successfully!</p>
                                    <p class="text-xs text-emerald-600">Sent to <strong>+91 @(mobile.Substring(0, 2))****@(mobile.Substring(mobile.Length - 2))</strong></p>
                                </div>
                            </div>

                            <form method="post" asp-action="VerifyOtp" asp-controller="Account" id="otpForm">
                                <input type="hidden" name="mobile" value="@mobile" />

                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-2">
                                        Enter OTP
                                    </label>
                                    <input type="tel"
                                           name="otp"
                                           id="otpInput"
                                           class="nia-input otp-input onlyNumber"
                                           maxlength="6"
                                           placeholder="• • • • • •"
                                           autocomplete="one-time-code"
                                           required />
                                    <p class="text-xs text-slate-400 mt-1.5 ml-1">Enter the 6-digit OTP sent to your mobile.</p>
                                </div>

                                <button type="submit" id="verifyBtn" class="nia-btn">
                                    <div class="spinner" id="verifySpinner"></div>
                                    <svg id="verifyIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span id="verifyText">Verify &amp; Login</span>
                                </button>

                                <!-- Resend -->
                                <div class="text-center mt-4">
                                    <p class="text-xs text-slate-500">
                                        Didn't receive OTP?
                                        <a href="/Account/Login" class="text-emerald-600 font-semibold hover:text-emerald-700 underline ml-1 transition-colors">
                                            Go back &amp; retry
                                        </a>
                                    </p>
                                </div>
                            </form>
                        }

                        <!-- Help -->
                        <div class="mt-8 pt-5 border-t border-slate-100 text-center">
                            <p class="text-xs text-slate-400">
                                Having trouble?
                                <span class="text-emerald-600 font-medium">Contact Helpdesk</span>
                                &nbsp;|&nbsp;
                                <a href="#" target="_blank" class="text-emerald-600 hover:underline">DCS</a>
                            </p>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </main>

    <!-- ─── Footer ─────────────────────────────────────────────────────────────── -->
    <footer class="bg-slate-900 text-slate-300 mt-12 border-t-4 border-emerald-500">
        <div class="max-w-7xl mx-auto px-6 py-7">
            <div class="flex flex-col md:flex-row justify-between items-center gap-5">
                <div class="flex items-center gap-3">
                    <div class="w-11 h-11 bg-white/10 rounded-xl flex items-center justify-center p-1.5 flex-shrink-0">
                        <img src="~/Logo/nia_logo.png" asp-append-version="true" alt="NIA Logo" class="w-full h-full object-contain" />
                    </div>
                    <div>
                        <p class="hindi text-white font-semibold text-sm">राष्ट्रीय आयुर्वेद संस्थान</p>
                        <p class="text-xs text-slate-400 uppercase tracking-wide">National Institute of Ayurveda</p>
                    </div>
                </div>
                <div class="text-center md:text-right">
                    <p class="text-xs text-slate-400">📍 Jorawar Singh Gate, Amer Road, Jaipur – 302002 (Raj.) INDIA</p>
                    <p class="text-xs text-slate-500 mt-1">© 2025 NIA Examination Portal · All rights reserved</p>
                </div>
            </div>
        </div>
    </footer>

    <script>
        /* ── Only-number inputs ─────────────────────────────────────────── */
        document.querySelectorAll('.onlyNumber').forEach(el => {
            el.addEventListener('input', function () {
                this.value = this.value.replace(/\D/g, '');
            });
            el.addEventListener('keypress', function (e) {
                if (!/[0-9]/.test(e.key)) e.preventDefault();
            });
        });

        /* ── Mobile form submit loading state ──────────────────────────── */
        const mobileForm = document.getElementById('mobileForm');
        if (mobileForm) {
            mobileForm.addEventListener('submit', function (e) {
                const mobile = document.getElementById('mobileInput').value.trim();
                if (!/^[6-9][0-9]{9}$/.test(mobile)) {
                    e.preventDefault();
                    showAlert('Please enter a valid 10-digit Indian mobile number.', 'warning');
                    return;
                }
                setBtnLoading('sendOtpBtn', 'sendSpinner', 'sendIcon', 'sendText', true, 'Sending...');
            });
        }

        /* ── OTP form submit loading state ─────────────────────────────── */
        const otpForm = document.getElementById('otpForm');
        if (otpForm) {
            otpForm.addEventListener('submit', function (e) {
                const otp = document.getElementById('otpInput').value.trim();
                if (otp.length !== 6) {
                    e.preventDefault();
                    showAlert('Please enter the complete 6-digit OTP.', 'warning');
                    return;
                }
                setBtnLoading('verifyBtn', 'verifySpinner', 'verifyIcon', 'verifyText', true, 'Verifying...');
            });
        }

        /* ── Helpers ───────────────────────────────────────────────────── */
        function setBtnLoading(btnId, spinnerId, iconId, textId, state, loadText) {
            const btn  = document.getElementById(btnId);
            const spin = document.getElementById(spinnerId);
            const icon = document.getElementById(iconId);
            const txt  = document.getElementById(textId);
            if (!btn) return;
            btn.disabled = state;
            if (spin) spin.classList.toggle('active', state);
            if (icon) icon.style.display = state ? 'none' : '';
            if (txt && loadText) txt.textContent = state ? loadText : txt.dataset.original || txt.textContent;
            if (!state && txt && txt.dataset.original) txt.textContent = txt.dataset.original;
            if (state && txt && loadText) { txt.dataset.original = txt.dataset.original || txt.textContent; }
        }

        function showAlert(msg, type) {
            const box = document.getElementById('alertBox');
            box.className = 'alert-box alert-' + type;
            box.style.display = 'block';
            box.innerHTML = `<div style="display:flex;align-items:center;gap:8px">
                <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span>${msg}</span></div>`;
            clearTimeout(box._timer);
            box._timer = setTimeout(() => {
                box.style.transition = 'opacity 0.3s';
                box.style.opacity = '0';
                setTimeout(() => { box.style.display = 'none'; box.style.opacity = '1'; }, 320);
            }, 5000);
        }
    </script>
</body>
</html>
