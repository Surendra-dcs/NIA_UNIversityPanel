
@{
    ViewData["Title"] = "IntBillDetails";
    Layout = null;
    @inject IConfiguration Configuration
    <script>
        var ApiBaseUrl = '@Configuration["ApiSettings:BaseUrl"]';
    </script>
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NIA - Office Order & Remuneration Voucher</title>
    <style>
        html {
            zoom: 100%;
        }

        @@page {
            size: A4;
            margin: 0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            transform: scale(1);
            transform-origin: top left;
            background: #c8bfb0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 11px;
            gap: 9px;
        }

        .page {
            background: #ffffff;
            width: 210mm;
            height: 336mm;
            overflow: hidden;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
        }

        .page-1 {
            padding: 6mm 12mm 4mm 12mm;
        }

        .p1-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-bottom: 5px;
            margin-bottom: 3px;
        }

        .p1-logo-box {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .p1-logo-box img {
                display: block;
                width: 100px;
                height: 100px;
                object-fit: contain;
            }

        .p1-header-center {
            flex: 1;
            text-align: center;
            padding: 0 8px;
        }

        .p1-hindi-title {
            font-size: 30px;
            font-weight: 700;
            color: #000;
            line-height: 1.2;
        }

        .p1-hindi-subtitle {
            font-size: 15px;
            font-weight: 400;
            color: #222;
            margin-top: 1px;
            line-height: 1.3;
        }

        .p1-eng-title {
            font-size: 20px;
            font-weight: 700;
            color: #000;
            margin-top: 3px;
            letter-spacing: 0.3px;
        }

        .p1-eng-subtitle {
            font-size: 13px;
            color: #222;
            margin-top: 1px;
            line-height: 1.35;
            font-weight: 600;
        }

        .p1-meta-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            font-size: 12px;
            color: #111;
            margin: 4px 0 5px 0;
            line-height: 1.3;
        }

        .p1-meta-date {
            text-align: right;
            font-size: 12px;
            line-height: 1.4;
        }

        .p1-doc-title {
            text-align: center;
            font-size: 16px;
            font-weight: 700;
            text-decoration: underline;
            margin-bottom: 5px;
            color: #000;
            letter-spacing: 0.3px;
        }

        .p1-intro {
            font-size: 13px;
            line-height: 1.45;
            margin-bottom: 6px;
            color: #111;
            text-align: justify;
        }

        .p1-main-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
        }

            .p1-main-table th,
            .p1-main-table td {
                border: 1px solid #000;
                padding: 2px 5px;
                vertical-align: top;
                line-height: 1.3;
                font-size: 11px;
            }

            .p1-main-table thead th {
                background-color: #f2f2f2;
                text-align: center;
                font-weight: 700;
                padding: 4px 5px;
                font-size: 12px;
            }

            .p1-main-table td:first-child {
                width: 8%;
                text-align: center;
                font-weight: 700;
            }

            .p1-main-table td:nth-child(2) {
                width: 62%;
            }

            .p1-main-table td:nth-child(3) {
                width: 30%;
                text-align: right;
                padding-right: 8px;
                white-space: nowrap;
            }

            .p1-main-table h1 {
                font-size: 12px;
                margin-bottom: 2px;
                font-weight: 700;
                line-height: 1.25;
            }

            .p1-main-table p {
                margin: 1px 0;
                padding-left: 8px;
                line-height: 1.25;
                font-size: 11px;
            }

        .p1-signature-area {
            height: 20px;
        }

        .p1-footer-address {
            border-top: 1px solid #aaa;
            padding-top: 4px;
            text-align: center;
            font-size: 11px;
            color: #222;
            line-height: 1.55;
        }

        .p1-footer-hindi {
            font-size: 13px;
        }

        .p1-footer-address a {
            color: #000;
            text-decoration: none;
        }

        .p1-page-bottom-bar {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: #555;
            margin-top: 4px;
        }

        /* ============================================================
                                                   PAGE 2 — NIA REMUNERATION VOUCHER
                                                   ============================================================ */
        .page-2 {
            padding: 8mm 11mm 4mm 11mm;
            font-size: 10px;
            line-height: 1.20;
        }

        .p2-top-meta {
            display: flex;
            justify-content: flex-end;
            align-items: flex-start;
            margin-bottom: 4px;
        }

        .p2-voucher-block {
            text-align: right;
            line-height: 1.3;
        }

        .p2-voucher-label {
            font-weight: bold;
            font-size: 11px;
            display: flex;
            align-items: center;
            gap: 4px;
            justify-content: flex-end;
        }

        .p2-voucher-blank {
            display: inline-block;
            width: 85px;
            border-bottom: 1.5px dotted #000;
            height: 14px;
        }

        .p2-office-use {
            font-size: 9px;
            font-style: normal;
            color: #555;
            text-align: right;
        }

        .p2-header {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            padding-bottom: 8px;
            margin-bottom: 6px;
        }

        .p2-logo {
            width: 56px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .p2-logo img {
                width: 100px;
                height: 80px;
                object-fit: contain;
                margin-right: 160px;
            }

        .p2-heading {
            text-align: center;
            line-height: 1.25;
        }

            .p2-heading h1 {
                font-size: 20px;
                font-weight: bold;
                letter-spacing: 0.6px;
                color: #1a1a1a;
            }

            .p2-heading p {
                font-size: 14px;
                margin: 1px 0;
                color: #333;
                font-weight: 600;
            }

        .p2-bank-section {
            margin: 4px 0;
            padding: 3px 2px;
        }

        .p2-bank-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 13px;
            gap: 150px;
        }

        .p2-bank-field {
            display: flex;
            align-items: center;
            flex: 1;
        }

        .p2-bank-field-label {
            white-space: nowrap;
            margin-right: 6px;
            font-weight: 600;
            font-size: 12px;
            min-width: 80px;
        }

        .p2-bank-field-line {
            flex: 1;
            border-bottom: 1.5px dotted #000;
            height: 14px;
            min-width: 10px;
        }

        .p2-form-title {
            text-align: center;
            font-weight: 700;
            font-size: 11px;
            text-decoration: underline;
            text-transform: uppercase;
            margin: 4px 0 6px 0;
            line-height: 1.3;
            letter-spacing: 0.4px;
            padding: 11px 39px;
            font-family: system-ui;
        }

        .p2-form-row {
            display: flex;
            align-items: center;
            width: 100%;
            gap: 0;
            margin-bottom: 11px;
            font-size: 9px;
            font-weight: 600;
            font-family: system-ui;
        }

        .p2-form-row-label {
            white-space: nowrap;
            font-weight: 400;
            font-size: 12px;
            padding-right: 6px;
            flex-shrink: 0;
        }

        .p2-form-row-line {
            flex: 1 1 0%;
            min-width: 0;
            border-bottom: 1.5px dotted #000;
            height: 16px;
        }

        .p2-form-group {
            display: flex;
            align-items: center;
            font-size: 12px;
            font-weight: 400;
            gap: 6px;
            width: 100%;
            margin-top: 11px;
            margin-bottom: 11px;
            font-family: system-ui;
            margin-left: 10px;
        }

        .p2-fg-label {
            white-space: nowrap;
            font-weight: 400;
            min-width: 60px;
            font-size: 12px;
            flex-shrink: 0;
        }

        .p2-fg-line-solid {
            flex: 1 1 0%;
            border-bottom: 1.5px dotted #000;
            height: 14px;
            min-width: 0;
        }

        .p2-fg-note {
            font-size: 9.5px;
            font-style: normal;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .p2-fg-hint {
            font-size: 9.5px;
            margin-bottom: 3px;
        }

        .p2-addr-row {
            display: flex;
            gap: 6px;
            align-items: center;
            width: 100%;
            font-size: 11px;
            margin-bottom: 13px;
            padding-left: 27%;
        }

        .p2-addr-label {
            white-space: nowrap;
            font-weight: 400;
            flex-shrink: 0;
        }

        .p2-addr-line-sm {
            border-bottom: 1px dotted #000;
            height: 14px;
            width: 90px;
            flex-shrink: 0;
        }

        .p2-addr-line-pin {
            border-bottom: 1px dotted #000;
            height: 14px;
            width: 60px;
            flex-shrink: 0;
        }

        .p2-examiner-row {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 7px;
            margin: 3px 0 3px 0;
            font-size: 12px;
            font-family: system-ui;
            margin-bottom: 12px;
        }

        .p2-ex-item {
            display: flex;
            align-items: center;
            font-size: 12px;
            font-weight: 400;
            gap: 4px;
        }

        .p2-ex-line {
            border-bottom: 1px dotted #000;
            height: 14px;
            width: 90px;
            flex-shrink: 0;
        }

        .p2-ex-line-sm {
            border-bottom: 1px dotted #000;
            height: 14px;
            width: 40px;
            flex-shrink: 0;
        }

        .p2-main-table {
            width: 100%;
            border-collapse: collapse;
            margin: 6px 0;
            font-size: 8px;
            table-layout: fixed;
        }

        .Remuneration-for {
            border-bottom: 0.5px solid #000;
            padding-bottom: 5px;
        }

        .p2-main-table th,
        .p2-main-table td {
            border: 0.5px solid #000;
            vertical-align: top;
            line-height: 1.2;
            word-wrap: break-word;
        }

        .p2-main-table thead th {
            font-weight: 600;
            font-size: 9px;
            padding-top: 3px;
            text-transform: uppercase;
            letter-spacing: 0.2px;
        }

            .p2-main-table thead th span {
                font-size: 8.5px;
                font-weight: 600;
            }

        .p2-th-sno {
            width: 8%;
        }

        .p2-th-remuneration {
            border: 8px solid yellow;
            width: 22%;
        }

        .p2-th-setting {
            width: 10%;
        }

        .p2-th-evaluate {
            width: 12%;
        }

        .p2-th-conducting {
            width: 31%;
        }

        .p2-th-rate {
            width: 6%;
        }

        .p2-th-amount {
            width: 7%;
        }

        .p2-th-remarks {
            width: 9%;
        }

        .p2-row-blank td {
            height: 44px;
        }

        .p2-row-net td {
            height: 16px;
            font-size: 11px;
            font-weight: bold;
            text-align: right;
            padding-right: 10px;
        }

        .p2-row-words td {
            height: 16px;
            font-size: 11px;
            text-align: left;
            padding-left: 10px;
        }

        .p2-signature-section {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 16px;
            min-height: 58px;
            margin-top: 19px;
        }

        .p2-sig-officer-box {
            flex: 1;
            display: flex;
            align-items: flex-end;
        }

        .p2-sig-officer-label {
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: 0.3px;
        }

        .p2-sig-examiner-box {
            width: 220px;
            text-align: center;
            font-size: 13px;
            line-height: 1.35;
        }

        .p2-sig-line {
            width: 160px;
            margin: 6px auto 3px;
            border-bottom: 1.5px solid #000;
            height: 14px;
        }

        .p2-sig-small {
            font-size: 9.5px;
            color: #555;
        }

        .p2-sig-received {
            display: block;
            margin-top: 1px;
            font-size: 13px;
            font-weight: 700;
        }

        .p2-footer {
            font-size: 11px;
            border-top: 2px solid #000;
        }

        .p2-footer-section-title {
            text-align: center;
            font-weight: bold;
            font-size: 12px;
            text-decoration: underline;
            text-transform: uppercase;
            margin: 3px 0 5px 0;
            letter-spacing: 0.4px;
            font-family: system-ui;
        }

        .p2-footer-para {
            font-size: 12px;
            margin-bottom: 5px;
            line-height: 1.4;
            font-family: system-ui;
        }

        .p2-footer-inline-line {
            display: inline-block;
            border-bottom: 1.5px dotted #000;
            width: 150px;
            height: 12px;
            vertical-align: bottom;
            margin: 0 4px;
        }

        .p2-footer-wide-line {
            display: inline-block;
            border-bottom: 1.5px dotted #000;
            width: 180px;
            height: 12px;
            vertical-align: bottom;
            margin: 0 4px;
        }

        .p2-footer-label-bold {
            font-weight: 400;
        }

        .p2-footer-controller {
            font-weight: 400;
            font-size: 13px;
            padding-bottom: 20px;
            margin: 30px 0 0 0;
            border-bottom: 2px solid #000;
            font-family: system-ui;
        }

        .p2-bottom-box {
            width: 100%;
            padding: 8px 6px 2px;
        }

        .p2-bottom-top-center {
            text-align: center;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        .p2-bottom-left {
            font-size: 11px;
            margin-bottom: 16px;
        }

        .p2-bottom-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            font-size: 11px;
        }

        .p2-bottom-center {
            text-align: center;
            font-size: 12px;
            flex: 1;
        }

        .p2-bottom-right {
            min-width: 200px;
            text-align: right;
            font-size: 12px;
        }

        /* ===== PRINT ===== */
        @@media print {
            body {
                background: none;
                padding: 0;
                gap: 0;
            }

            .page {
                box-shadow: none;
                width: 210mm;
                height: 314mm;
                overflow: hidden;
            }

            .page-1 {
                page-break-after: always;
            }

            .page-2 {
                page-break-before: always;
            }
        }

        .kk {
            height: 24px;
            width: 61px;
            background: #080e7e;
            color: white;
            font-weight: 700;
            font-size: 13px;
            border-radius: 9px;
            margin-left: 718px;
        }

        .p2-main-table tbody tr td {
            line-height: 4
        }

        @@media print {
            .no-print {
                display: none !important;
            }

            body {
                margin: 0;
                padding: 0;
                background: white;
            }

            .page {
                width: 100%;
                margin: 0;
                padding: 15px;
                box-shadow: none !important;
                border: none !important;
            }
            /* Remove layout/sidebar/navbar */
            header,
            nav,
            aside,
            footer,
            .sidebar,
            .topbar,
            .navbar,
            .admin-sidebar,
            .admin-header {
                display: none !important;
            }
            /* Full width */
            .container,
            .container-fluid,
            .content-wrapper,
            .main-content {
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            table {
                page-break-inside: avoid;
            }

            .page-break {
                page-break-before: always;
            }
        }

        .p2-main-table tbody tr td {
            line-height: 2
        }
    </style>
    <script src="~/js/printbill.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
</head>
<body>
    <div id="profileError" style="display:none;">
        <h2 style="color:red;text-align:center;">
            Your profile is incomplete, or the student's practical marks have not been saved.
        </h2>
    </div>
    <div class="text-end mb-3 no-print">
        <button type="button" class="kk" onclick="printBill()">
            Print
        </button>
    </div>
    <div class="page page-2" id="voucherPage">

        <!-- TOP META -->
        <div class="p2-top-meta">
            <div class="p2-voucher-block">
                <div class="p2-voucher-label">
                    Voucher No.
                    <span class="p2-voucher-blank" id="VoucherNo"></span>
                </div>
                <div class="p2-office-use">(For Office Use Only)</div>
            </div>
        </div>

        <!-- HEADER -->
        <div class="p2-header">
            <div class="p2-logo">
                <img src="~/Logo/nia_logo.png" alt="NIA Logo" />
            </div>
            <div class="p2-heading">
                <h1>NATIONAL INSTITUTE OF AYURVEDA</h1>
                <p>Deemed To Be University (De Novo)</p>
                <p>(Ministry of AYUSH, Govt. of India)</p>
                <p>Jorawar Singh Gate, Amer Road, Jaipur-302002 (Raj.)</p>
            </div>
        </div>

        <!-- BANK DETAILS -->
        <div class="p2-bank-section">
            <div class="p2-bank-row">
                <div class="p2-bank-field">
                    <span class="p2-bank-field-label">Name of Bank</span>
                    <span class="p2-bank-field-line" id="BankName"></span>
                </div>
                <div class="p2-bank-field">
                    <span class="p2-bank-field-label">Mob. No.</span>
                    <span class="p2-bank-field-line" id="MobileNo"></span>
                </div>
            </div>

            <div class="p2-bank-row">
                <div class="p2-bank-field">
                    <span class="p2-bank-field-label">Bank A/c No.</span>
                    <span class="p2-bank-field-line" id="BankAccountNo"></span>
                </div>
                <div class="p2-bank-field">
                    <span class="p2-bank-field-label">E-Mail I.D.</span>
                    <span class="p2-bank-field-line" id="Email"></span>
                </div>
            </div>

            <div class="p2-bank-row">
                <div class="p2-bank-field">
                    <span class="p2-bank-field-label">IFSC Code</span>
                    <span class="p2-bank-field-line" id="IFSCCode"></span>
                </div>
                <div class="p2-bank-field">
                    <span class="p2-bank-field-label">PAN No.</span>
                    <span class="p2-bank-field-line" id="PANNo"></span>
                </div>
            </div>
        </div>

        <!-- TITLE -->
        <div class="p2-form-title">
            <strong>
                REMUNERATION BILL FOR SETTING QUESTION PAPER / THEORY ANSWER BOOK EVALUATION<br /> OR
                RE-EVALUATION / PRACTICAL OR VIVA EXAMINATION / THESIS EVALUATION
            </strong>
        </div>

        <!-- EXAMINER NAME -->
        <div class="p2-form-group">
            <span class="p2-fg-label">Name of Examiner :<br /> (as in Bank A/C)</span>
            <span class="p2-fg-line-solid" style="margin-top:-13px" id="ExaminerName"></span>
            <span class="p2-fg-note" style="margin-top:-13px">(IN BLOCK LETTERS)</span>
        </div>

        <!-- EXAMINER DETAILS -->
        <div class="p2-examiner-row">
            <span class="p2-fg-label">Examiner Details :</span>

            <div class="p2-ex-item">
                <span>Qualification : </span>
                <span class="p2-ex-line" id="Qualification"></span>
            </div>

            <div class="p2-ex-item">
                <span>Specialization : </span>
                <span class="p2-ex-line" id="Specialization"></span>
            </div>

            <div class="p2-ex-item">
                <span>Teaching Exp. UG : </span>
                <span class="p2-ex-line-sm" id="TeachingUG"></span>
            </div>

            <div class="p2-ex-item">
                <span>PG : </span>
                <span class="p2-ex-line-sm" id="TeachingPG"></span>
            </div>
        </div>

        <!-- COLLEGE ADDRESS -->
        <div class="p2-form-row">
            <span class="p2-form-row-label">Name of College with Address :</span>
            <span class="p2-form-row-line" id="CollegeAddress"></span>
        </div>

        <div class="p2-addr-row">
            <span class="p2-addr-label">City:</span>
            <span class="p2-addr-line-sm" id="CollegeCity"></span>

            <span class="p2-addr-label">Dist.:</span>
            <span class="p2-addr-line-sm" id="CollegeDistrict"></span>

            <span class="p2-addr-label">State:</span>
            <span class="p2-addr-line-sm" id="CollegeState"></span>

            <span class="p2-addr-label">Pin:</span>
            <span class="p2-addr-line-pin" id="CollegePinCode"></span>
        </div>

        <!-- RESIDENTIAL ADDRESS -->
        <div class="p2-form-row">
            <span class="p2-form-row-label">Residential Address :</span>
            <span class="p2-form-row-line" style="margin-left:9%;" id="ResidentialAddress"></span>
        </div>

        <div class="p2-addr-row">
            <span class="p2-addr-label">City:</span>
            <span class="p2-addr-line-sm" id="ResidentialCity"></span>
            <span class="p2-addr-label">Dist.:</span>
            <span class="p2-addr-line-sm" id="ResidentialDistrict"></span>
            <span class="p2-addr-label">State:</span>
            <span class="p2-addr-line-sm" id="ResidentialState"></span>
            <span class="p2-addr-label">Pin:</span>
            <span class="p2-addr-line-pin" id="ResidentialPinCode"></span>
        </div>

        <!-- EXAM DETAILS -->
        <div class="p2-form-row">
            <span class="p2-form-row-label">Name of the Examination : </span>
            <span class="p2-form-row-line" id="ExamName"></span>
        </div>

        <div class="p2-fg-hint">
            (Course type BAMS/MD/MS/M.Sc./Ph.D./Diploma Certificate With Month Year)
        </div>

        <div class="p2-form-group">
            <span class="p2-fg-label">Subject & Paper : </span>
            <span class="p2-fg-line-solid" id="SubjectName"></span>
        </div>

        <!-- MAIN TABLE -->
        <table class="p2-main-table">
            <thead>
                <tr>
                    <th rowspan="2" style="width:34px;">S.No./Assigned Id </th>
                    <th>Remuneration For</th>
                    <th rowspan="2"> No of Setting Question Paper </th>
                    <th rowspan="2">No of Evaluate or Re evaluate Answer book / Thesis </th>
                    <th colspan="3">Conducting Practical Exam & Viva-Voce</th>
                    <th rowspan="2">Rate</th>
                    <th rowspan="2">Amount</th>
                    <th rowspan="2">Remarks (Postal Charge or others)</th>
                </tr>
                <tr>
                    <th style="width:89px;">
                        SETTING QUESTION PAPER /
                        THEORY ANSWER BOOK
                        EVALUATION OR
                        RE-EVALUATION/
                        CONDUCTING  PRACTICAL
                        OR VIVA EXAMINATION /
                        THESIS EVALUATION
                    </th>
                    <th>
                        No of
                        candidates
                        Registered
                    </th>
                    <th>
                        No of
                        Candidate
                        absent form
                        Examination
                    </th>
                    <th>
                        No of
                        candidate
                        actually
                        examined
                    </th>
                </tr>
            </thead>

            <tbody style="text-align: center;">
                <tr>
                    <td>1</td>
                    <td>
                        PRACTICAL AND VIVA EXAMINATION
                    </td>
                    <td>0</td>
                    <td>0</td>
                    <td>0</td>
                    <td>0</td>
                    <td id="TotalStudent"></td>
                    <td id="Rate"></td>
                    <td id="TotalAmount"></td>
                    <td>-</td>
                </tr>

                <tr class="p2-row-net">
                    <td colspan="8">Net Payable Amount Rs.</td>
                    <td id="NetPayable"></td>
                    <td></td>
                </tr>

                <tr class="p2-row-words">
                    <td></td>
                    <td colspan="8"><strong> Total Amount in words : <span id="AmountInWords"></span> Only </strong></td>
                    <td></td>
                </tr>
            </tbody>
        </table>

        <!-- SIGNATURE -->
        <div class="p2-signature-section">
            <div class="p2-sig-officer-box">
                <p class="p2-sig-officer-label">VERIFYING OFFICER (DCOE)</p>
            </div>

            <div class="p2-sig-examiner-box">
                <img id="ExaminnerSignature" src="" style="height:20px;width:80px" /><br />
                (Signature of the Examiner)<br />
                <span class="p2-sig-small">(This bill not claimed before)</span>
                <span class="p2-sig-received">Received Payment</span>
            </div>
        </div>

        <!-- FOOTER -->
        <div class="p2-footer">

            <div class="p2-footer-section-title">
                FOR USE IN CONTROLLER OF EXAMINATION SECTION
            </div>

            <p class="p2-footer-para">
                It is certified that Particulars given above are correct.  Forwarded for payment only after checking by the Accountant Section.
            </p>

            <p class="p2-footer-para" style="display:flex; align-items:center; gap:5px;margin-top:4%;">
                The sum of Rs.
                <span style="display:inline-block; width:109px; border-bottom:1.5px dotted #000;"></span>
                (In word)
                <span style="display:inline-block; width:250px; border-bottom:1.5px dotted #000;"></span>
                may be paid
            </p>

            <p class="p2-footer-controller">
                CONTROLLER OF EXAMINATIONS
            </p>

            <div class="p2-footer-section-title">
                FOR USE IN ACCOUNT SECTION
            </div>

            <p class="p2-footer-para">
                Total remuneration claimed Rs. <span id="FooterTotalAmount"></span>
            </p>

            <p class="p2-footer-para">
                Deduction 10% (If any) __________
            </p>

            <p class="p2-footer-para p2-footer-label-bold">
                Net Payable Amount Rs.  <span id="FooterNetPayable"></span>
            </p>

            <div class="p2-bottom-box">
                <div class="p2-bottom-top-center">
                    Dealing Person of Account Section
                </div>

                <div class="p2-bottom-left">
                    Checked & Verified by
                </div>

                <div class="p2-bottom-row">
                    <div></div>
                    <div class="p2-bottom-center">
                        Accountant / AAO / AO
                    </div>
                    <div class="p2-bottom-right">
                        Dated __________
                    </div>
                </div>
            </div>

        </div>

    </div>

    <script>
        $(document).ready(function () {
            var emailid = '@Context.Session.GetString("Email")';
            $.ajax({
                 url: ApiBaseUrl + 'PracticalMarks/GetExbill?emailid=' + encodeURIComponent(emailid),
                type: 'GET',
                success: function (res) {
                    if (!res || !res.length) {
                        $("#profileError").show();
                        $("#voucherPage").hide();
                        $(".no-print").hide();
                        return;
                    }

                    let data = res[0];

                    bindVoucher(data);
                },
                error: function () {
                    $("#profileError").show();
                    $("#voucherPage").hide();
                     $(".no-print").hide();
                }
            });
        });
         function bindVoucher(data) {
            debugger
            $("#VoucherNo").text(data.voucherNo || '');
            $("#BankName").text(data.bankName || '');
            $("#MobileNo").text(data.mobileNo || '');
            $("#BankAccountNo").text(data.bankAccountNo || '');
            $("#Email").text(data.email || '');
            $("#IFSCCode").text(data.ifscCode || '');
            $("#PANNo").text(data.panNo || '');

            $("#ExaminerName").text(data.examinerName || '');
            $("#Qualification").text(data.qualification || '');
            $("#Specialization").text(data.specialization || '');
            $("#TeachingUG").text(data.teachingUG || '');
            $("#TeachingPG").text(data.teachingPG || '');

            $("#CollegeAddress").text(data.collegeAddress || '');
            $("#CollegeCity").text(data.collegeCity || '');
            $("#CollegeDistrict").text(data.collegeDistrict || '');
            $("#CollegeState").text(data.collegeState || '');
            $("#CollegePinCode").text(data.collegePinCode || '');

            $("#ResidentialAddress").text(data.residentialAddress || '');
            $("#ResidentialCity").text(data.residentialCity || '');
            $("#ResidentialDistrict").text(data.residentialDistrict || '');
            $("#ResidentialState").text(data.residentialState || '');
            $("#ResidentialPinCode").text(data.residentialPinCode || '');

            $("#ExamName").text(data.examName || '');
            $("#SubjectName").text(data.subjectName || '');
            $("#TotalStudent").text(data.totalStudent || 0);
            $("#TotalAmount").text(data.totalAmount || 0);
            $("#NetPayable").text(data.netPayable || 0);
            $("#FooterTotalAmount").text(data.totalAmount || 0);
            $("#FooterNetPayable").text(data.netPayable || 0);

            let rate = 0;

            if ((data.totalStudent || 0) > 0) {
                rate = (data.totalAmount / data.totalStudent).toFixed(2);
            }

            $("#Rate").text(rate);

            if (data.examinnerSignature) {
                $("#ExaminnerSignature").attr("src", data.examinnerSignature);
            }

            $("#AmountInWords").text(data.amountInWords || '');
        }
    </script>
</body>
</html>
