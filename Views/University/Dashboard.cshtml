@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}

<div class="stats-grid">
    <div class="stat-card card-students">
        <div class="stat-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-label">Total Students</div>
            <div class="stat-number" id="totalStudents">—</div>
            <div class="stat-badge badge-up">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15" /></svg>
                Enrolled in exams
            </div>
        </div>
        <div class="stat-sparkline">
            <svg viewBox="0 0 80 30" preserveAspectRatio="none">
                <polyline points="0,25 15,18 28,22 40,10 55,14 70,6 80,9" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" />
            </svg>
        </div>
    </div>

    <div class="stat-card card-courses">
        <div class="stat-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-label">Total Courses</div>
            <div class="stat-number" id="totalCourses">—</div>
            <div class="stat-badge badge-up">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15" /></svg>
                Active courses
            </div>
        </div>
        <div class="stat-sparkline">
            <svg viewBox="0 0 80 30" preserveAspectRatio="none">
                <polyline points="0,22 15,19 28,15 40,17 55,9 70,11 80,7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" />
            </svg>
        </div>
    </div>

    <div class="stat-card card-programs">
        <div class="stat-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-label">Total Subjects</div>
            <div class="stat-number" id="totalSubjects">—</div>
            <div class="stat-badge badge-neutral">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                Across all courses
            </div>
        </div>
        <div class="stat-sparkline">
            <svg viewBox="0 0 80 30" preserveAspectRatio="none">
                <polyline points="0,15 15,14 28,16 40,13 55,15 70,14 80,14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" />
            </svg>
        </div>
    </div>

    <div class="stat-card card-admissions">
        <div class="stat-icon-wrap">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
        </div>
        <div class="stat-body">
            <div class="stat-label">Enrolled Students</div>
            <div class="stat-number" id="totalActiveStudents">—</div>
            <div class="stat-badge badge-up">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15" /></svg>
                Verified enrollments
            </div>
        </div>
        <div class="stat-sparkline">
            <svg viewBox="0 0 80 30" preserveAspectRatio="none">
                <polyline points="0,26 15,20 28,17 40,12 55,8 70,5 80,3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" />
            </svg>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-header">
        <h2 class="section-title">Recent Admissions (Roll List)</h2>
    </div>
    <div class="table-wrap table table-responsive">
        <table class="data-table" id="dashboardTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Roll Number</th>
                    <th>Student Name</th>
                    <th>Email</th>
                    <th>Course</th>
                    <th>Semester</th>
                    <th>Exam</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody id="dashboardTbody">
                <tr><td colspan="8" class="text-center">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<script>
    $(document).ready(function () {

        // Helper: animate count from 0 to target
        function animateCount(elementId, target) {
            var el = document.getElementById(elementId);
            var start = 0;
            var duration = 800;
            var step = Math.ceil(target / (duration / 16));
            var timer = setInterval(function () {
                start += step;
                if (start >= target) {
                    start = target;
                    clearInterval(timer);
                }
                el.textContent = start;
            }, 16);
        }

        // 1. Total Students + Recent Admissions table — from Exam/rolllist
        fetch(ApiBaseUrl + 'Exam/rolllist')
            .then(res => res.json())
            .then(function (data) {
                animateCount('totalStudents', data.length);

                var tbody = document.getElementById('dashboardTbody');
                tbody.innerHTML = '';

                if (data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="8" class="text-center">No enrolled students found.</td></tr>';
                    return;
                }

                data.forEach(function (row, index) {
                    tbody.innerHTML += `
                        <tr>
                            <td class="row-num">${index + 1}</td>
                            <td>${row.rollNumber ?? ''}</td>
                            <td><div class="student-cell"><span>${row.userName ?? ''}</span></div></td>
                            <td>${row.email ?? ''}</td>
                            <td>${row.courseName ?? ''}</td>
                            <td>${row.semesterName ?? ''}</td>
                            <td>${row.examName ?? ''}</td>
                            <td><span class="status-pill status-active">Active</span></td>
                        </tr>`;
                });
            })
            .catch(function () {
                document.getElementById('dashboardTbody').innerHTML =
                    '<tr><td colspan="8" class="text-center text-danger">Failed to load data.</td></tr>';
                document.getElementById('totalStudents').textContent = 'N/A';
            });

        // 2. Total Courses — from Course/GetCourses
        fetch(ApiBaseUrl + 'Course/GetCourses')
            .then(res => res.json())
            .then(function (data) {
                animateCount('totalCourses', data.length);
            })
            .catch(function () {
                document.getElementById('totalCourses').textContent = 'N/A';
            });

        // 3. Total Subjects — from Subject/list
        fetch(ApiBaseUrl + 'Subject/list')
            .then(res => res.json())
            .then(function (data) {
                animateCount('totalSubjects', data.length);
            })
            .catch(function () {
                document.getElementById('totalSubjects').textContent = 'N/A';
            });

        // 4. Active Students — from StudentEnrollment/GetStudentEnrollmentList (isVerify === true)
       fetch(ApiBaseUrl + 'StudentEnrollment/GetStudentEnrollmentList')
    .then(res => res.json())
    .then(function (data) {
        // Debug: log to console so you can inspect actual values
        console.log('Enrollment data sample:', data.slice(0, 3));
        console.log('Total enrollment records:', data.length);

        // Handle bool true OR numeric 1 (SQL bit can come as either)
        var active = data.filter(s => s.isVerify === true || s.isVerify === 1).length;
        console.log('Active (verified) count:', active);

        // If NO one is verified yet, show total enrolled instead as fallback
        animateCount('totalActiveStudents', active);
    })
    .catch(function () {
        document.getElementById('totalActiveStudents').textContent = 'N/A';
    });

    });
</script>