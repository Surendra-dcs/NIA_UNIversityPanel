@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<style>
    .section-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 25px;
        box-shadow: 0 3px 12px rgba(0,0,0,.08);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 1px solid #e5e5e5;
    }

    .section-title {
        margin: 0;
        font-size: 24px;
        font-weight: 600;
        color: #2c3e50;
    }

    .badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 30px;
        color: #fff;
        font-size: 13px;
        margin-left: 10px;
    }

    .badge-primary {
        background: #1a3a5c;
    }

    .badge-success {
        background: #198754;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
        gap: 20px;
    }

    .stat-card {
        background: #fff;
        border-radius: 10px;
        padding: 20px;
        display: flex;
        align-items: center;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        border-left: 5px solid #1a3a5c;
    }

    .stat-icon-wrap {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        background: #eef5ff;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-right: 15px;
        color: #1a3a5c;
    }

    .stat-label {
        color: #777;
        font-size: 14px;
    }

    .stat-number {
        font-size: 30px;
        font-weight: bold;
        margin: 8px 0;
    }

    .stat-badge {
        font-size: 13px;
        color: #198754;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th {
            background: #1a3a5c;
            color: #fff;
            padding: 14px;
            text-align: center;
            border: 1px solid #dee2e6;
        }

        .data-table td {
            padding: 12px;
            border: 1px solid #dee2e6;
        }
        .data-table tbody tr {
            border-bottom: 1px solid #cfd4da;
        }

            .data-table tbody tr:hover {
                background: #f8f9fa;
            }
        .data-table td:nth-child(2),
        .data-table td:nth-child(3),
        .data-table th:nth-child(2),
        .data-table th:nth-child(3) {
            text-align: left;
            padding-left: 15px;
        }

</style>

@{
    var courseId = Context.Session.GetInt32("CourseId") ?? 0;
    var rollId = Context.Session.GetInt32("Role") ?? 0;
}
@if (courseId == 5||courseId == 32 && rollId==4)
{
    <div class="section-card">
        <div class="section-header">
            <h2 class="section-title">
                Welcome
            </h2>
        </div>
    </div>
}
else
{
    <div class="section-card">

        <div class="section-header">
            <h2 class="section-title">
                MD/MS (Ay.) Exam Form Filling Details
                <span class="badge badge-primary">May 2026</span>
            </h2>
        </div>

        <div class="stats-grid">

            <div class="stat-card">
                <div class="stat-icon-wrap">👨‍🎓</div>

                <div>
                    <div class="stat-label">Total Enrolled Students</div>
                    <div class="stat-number" id="totalActiveStudents">—</div>
                    <div class="stat-badge">Verified Enrollments</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon-wrap">📝</div>

                <div>
                    <div class="stat-label">Total Exam Forms</div>
                    <div class="stat-number" id="totalStudents">—</div>
                    <div class="stat-badge">Enrolled in Exams</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon-wrap">📚</div>

                <div>
                    <div class="stat-label">Total Courses</div>
                    <div class="stat-number" id="totalCourses">—</div>
                    <div class="stat-badge">Active Courses</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon-wrap">📖</div>

                <div>
                    <div class="stat-label">Total Subjects</div>
                    <div class="stat-number" id="totalSubjects">—</div>
                    <div class="stat-badge">Across All Courses</div>
                </div>
            </div>

        </div>

    </div>
    <!-- ================= BAMS ================= -->
    <div class="section-card">
        <div class="section-header">
            <h2 class="section-title">
                BAMS Exam Form Filling Details
                <span class="badge badge-success">July–August 2026</span>
            </h2>
        </div>
        <div class="table-wrap">
            <table class="data-table" id="dashboardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Course</th>
                        <th>Semester / Year</th>
                        <th>Total Students</th>
                        <th>Forms Filled</th>
                        <th>Pending Forms</th>
                    </tr>
                </thead>
                <tbody id="dashboardTbody">
                    <tr>
                        <td colspan="6">
                            Loading...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="section-card">
        <div class="section-header">
            <h2 class="section-title">
                New Exam Form Filling Details
                <span class="badge badge-success">July–August 2026</span>
            </h2>
        </div>
        <div class="table-wrap">
            <table class="data-table" id="dashboardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Course</th>
                        <th>Semester / Year</th>
                        <th>Total Students</th>
                        <th>Total Enrolled</th>
                        <th>Total Exam Form</th>
                    </tr>
                </thead>
                <tbody id="dashboardNewDT">
                    <tr>
                        <td colspan="6">
                            Loading...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
}

<script>
    $(document).ready(function () {
        loadDashboardCounts();       
        loadDashboardData();  
        loadDashboardNewData();
    });
     function loadDashboardCounts() {
        $.ajax({
            url: ApiBaseUrl + 'Exam/Dashboardcount',
            type: 'GET',
              success: function (res) {
                $("#totalActiveStudents").text(
                   res.totalApplications ?? 0
                );
                $("#totalStudents").text(
                     res.totalRollNumbers ?? 0
                );
                $("#totalCourses").text(
                    res.totalCourses ?? 0
                );
                $("#totalSubjects").text(
                    res.totalSubjects ?? 0
                );
            },
            error: function (xhr, status, error) {
                console.log("Dashboard count load failed");
                console.log(error);
            }
        });
    }

     function loadDashboardData() {
        fetch(ApiBaseUrl + 'DashboardDT/GetDashboardCount')
            .then(res => res.json())
            .then(function (data) {
                var tbody = document.getElementById('dashboardTbody');
                tbody.innerHTML = '';
                if (!data || data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="6" class="text-center">
                                No record found.
                            </td>
                        </tr>`;
                    return;
                }
                data.forEach(function (row, index) {
                    tbody.innerHTML += `
                        <tr>
                            <td class="row-num">${index + 1}</td>                           
                            <td>${row.course_name ?? ''}</td>
                            <td>${row.semyearname ?? ''}</td>
                            <td>${row.totalStudents ?? ''}</td>
                            <td>${row.formFilled ?? ''}</td>
                            <td>${row.pendingForms ?? ''}</td>                            
                        </tr>`;
                });

            })
            .catch(function (error) {
                console.error(error);
                document.getElementById('dashboardTbody').innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center text-danger">
                            Failed to load data.
                        </td>
                    </tr>`;
            });      
    }

     function loadDashboardNewData() {
        fetch(ApiBaseUrl + 'DashboardDT/GetstudentDAtaforNewForm')
            .then(res => res.json())
            .then(function (data) {
                var tbody = document.getElementById('dashboardNewDT');
                tbody.innerHTML = '';
                if (!data || data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="6" class="text-center">
                                No record found.
                            </td>
                        </tr>`;
                    return;
                }
                data.forEach(function (row, index) {
                    tbody.innerHTML += `
                        <tr>
                            <td class="row-num">${index + 1}</td>
                            <td>${row.course_name ?? ''}</td>
                            <td>${row.semyearname ?? ''}</td>
                            <td>${row.totalStudents ?? ''}</td>
                            <td>${row.totalEnrolled ?? ''}</td>
                            <td>${row.totalexamformfilling ?? ''}</td>
                        </tr>`;
                });

            })
            .catch(function (error) {
                console.error(error);
                document.getElementById('dashboardNewDT').innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center text-danger">
                            Failed to load data.
                        </td>
                    </tr>`;
            });
    }
</script>