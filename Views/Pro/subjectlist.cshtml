
@{
    ViewData["Title"] = "subjectlist";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />
<div class="table-card">

    <div class="table-header">
        <h3 class="table-title">Subjetc List</h3>
        <div class="table-actions">
            <select id="statusFilter" class="filter-select">
                <option value="">All Status</option>
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </select>
            <button class="btn btn-success" onclick="openSubjectModal()">Add Subject</button>
        </div>
    </div>
    <div class="table-responsive">
        <table id="subjectTable" class="display custom-table">
            <thead>
                <tr>
                    <th>Sr.No.</th>
                    <th>Program Name</th>
                    <th>Course Name</th>
                    <th>Subject Name</th>
                    <th>Subject Code</th>
                    <th>Semester/Part</th>
                    <th>Status</th>
                    <th style="text-align:center;">Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
<!-- Modal -->
<div class="modal fade" id="subjectModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <!-- Header -->
            <div class="modal-header">
                <h5 class="modal-title">Add / Edit Subject</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- Body -->
            <div class="modal-body">
                <input type="hidden" id="subjectId" value="0" />

                <div class="row g-3">
                    <!-- ✅ spacing fix -->

                    <div class="col-md-6">
                        <label class="form-label">Program</label>
                        <select id="programDropdown" class="form-select">
                            <option value="">Select Program</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Course</label>
                        <select id="courseDropdown" class="form-select">
                            <option value="">Select Course</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Subject Name</label>
                        <input type="text" id="subjectName" class="form-control" placeholder="Enter Subject Name">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Subject Code</label>
                        <input type="text" id="subjectCode" class="form-control" placeholder="Enter Subject Code">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select id="status" class="form-select">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>

                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeCourseModal()" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="saveSubject()">Save</button>
            </div>

        </div>
    </div>
</div>
