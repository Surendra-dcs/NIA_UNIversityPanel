@{
    ViewData["Title"] = "addExaminer";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}

<style>
    .examiner-page {
        background: #f1f5f9;
        min-height: 100vh;
        padding: 32px 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    .register-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07), 0 1px 4px rgba(0,0,0,0.04);
        max-width: 920px;
        margin: 0 auto;
    }

    /* ─── Header ─── */
    .register-header {
        background: linear-gradient(135deg, #059669 0%, #0d9488 60%, #0f766e 100%);
        padding: 10px 32px;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .register-header::before {
            content: '';
            position: absolute;
            top: -50px;
            right: -50px;
            width: 180px;
            height: 180px;
            background: rgba(255,255,255,0.07);
            border-radius: 50%;
        }

        .register-header::after {
            content: '';
            position: absolute;
            bottom: -70px;
            right: 100px;
            width: 240px;
            height: 240px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
        }

    .header-icon {
        width: 48px;
        height: 48px;
        background: rgba(255,255,255,0.18);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 14px;
        border: 1px solid rgba(255,255,255,0.25);
        position: relative;
        z-index: 1;
    }

    .register-header h3 {
        margin: 0;
        font-weight: 700;
        font-size: 22px;
        position: relative;
        z-index: 1;
    }

    .register-header p {
        margin: 6px 0 0;
        opacity: 0.88;
        font-size: 13.5px;
        position: relative;
        z-index: 1;
    }

    /* ─── Card Body ─── */
    .register-body {
        padding: 36px 40px;
    }

    /* ─── Section Title ─── */
    .section-title {
        font-size: 11.5px;
        font-weight: 700;
        color: #059669;
        text-transform: uppercase;
        letter-spacing: 1.6px;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
    }

        .section-title::before {
            content: '';
            width: 26px;
            height: 3px;
            background: linear-gradient(90deg, #059669, #10b981);
            border-radius: 2px;
            flex-shrink: 0;
        }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, #d1fae5, transparent);
        }

    /* ─── TWO-COLUMN GRID (No Bootstrap needed) ─── */
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px 28px;
        margin-bottom: 4px;
    }

        .form-grid .field-wrap {
            display: flex;
            flex-direction: column;
        }

    /* ─── Labels ─── */
    .form-label {
        font-weight: 600;
        font-size: 12px;
        color: #475569;
        margin-bottom: 7px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .form-label i {
            color: #059669;
            font-size: 11px;
        }

    /* ─── Icon Input Wrapper ─── */
    .input-icon-wrap {
        position: relative;
    }

        .input-icon-wrap .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #059669;
            font-size: 13px;
            pointer-events: none;
            z-index: 2;
        }

        .input-icon-wrap .form-ctrl,
        .input-icon-wrap .form-sel {
            padding-left: 40px;
        }

    /* ─── Inputs & Selects ─── */
    .form-ctrl,
    .form-sel {
        border-radius: 10px;
        padding: 11px 14px;
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #1e293b;
        transition: all 0.2s ease;
        box-shadow: none;
        font-size: 14px;
        width: 100%;
        height: 46px;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
        outline: none;
        appearance: auto;
    }

        .form-ctrl::placeholder {
            color: #94a3b8;
            font-size: 13.5px;
        }

        .form-ctrl:focus,
        .form-sel:focus {
            border-color: #059669;
            background: #f0fdf4;
            box-shadow: 0 0 0 3px rgba(5,150,105,0.12);
            color: #1e293b;
        }

    .input-icon-wrap:focus-within .field-icon {
        color: #047857;
    }

    .form-sel {
        cursor: pointer;
    }

    /* Readonly role field */
    .form-ctrl[readonly] {
        background: #ecfdf5;
        border-color: #a7f3d0;
        color: #065f46;
        font-weight: 700;
        cursor: not-allowed;
    }

    /* ─── Divider ─── */
    .section-divider {
        border: none;
        border-top: 1.5px dashed #e2e8f0;
        margin: 8px 0 28px;
    }

    /* ─── Submit Button ─── */
    .btn-register {
        background: linear-gradient(135deg, #059669 0%, #0d9488 100%);
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 700;
        font-size: 15px;
        color: white;
        letter-spacing: 0.4px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        box-shadow: 0 6px 20px rgba(5,150,105,0.3);
        width: 100%;
        cursor: pointer;
        font-family: 'Segoe UI', sans-serif;
        margin-top: 8px;
    }

        .btn-register::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
            transition: left 0.5s ease;
        }

        .btn-register:hover::before {
            left: 100%;
        }

        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(5,150,105,0.38);
            color: white;
        }

        .btn-register:active {
            transform: translateY(0);
        }

    /* ─── Alerts ─── */
    #msg .alert {
        border-radius: 10px;
        font-size: 13.5px;
        font-weight: 500;
        padding: 13px 18px;
        margin-bottom: 22px;
    }

    #msg .alert-success {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    #msg .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    /* ─── Responsive ─── */
    @@media (max-width: 640px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .register-body {
            padding: 24px 18px;
        }

        .register-header {
            padding: 22px 20px;
        }
    }
</style>

<div class="examiner-page">
    <div class="register-card">

        <!-- Header -->
        <div class="register-header">
            <div class="header-icon">
                <i class="fa fa-user-tie"></i>
            </div>
            <h3>Examiner Registration</h3>
            <p>Register examiner details for examination portal access</p>
        </div>

        <!-- Body -->
        <div class="register-body">

            <div id="msg"></div>

            <form id="registerForm">

                <!-- ══ Basic Information ══ -->
                <div class="section-title">Basic Information</div>

                <div class="form-grid">

                    <!-- Username -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-user"></i> User Name
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-user field-icon"></i>
                            <input type="text"
                                   class="form-ctrl"
                                   id="username"
                                   placeholder="Enter full name"
                                   required />
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-envelope"></i> Email Address
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-envelope field-icon"></i>
                            <input type="email"
                                   class="form-ctrl"
                                   id="email"
                                   placeholder="Enter email address"
                                   required />
                        </div>
                    </div>

                 @*    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-lock"></i> Password
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-lock field-icon"></i>
                            <input type="password"
                                   class="form-ctrl"
                                   id="password"
                                   placeholder="Enter password"
                                   required />
                        </div>
                    </div> *@

                    <!-- Mobile -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-phone"></i> Mobile Number
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-phone field-icon"></i>
                            <input type="text"
                                   class="form-ctrl"
                                   id="mobile"
                                   maxlength="10"
                                   placeholder="Enter mobile number"
                                   required />
                        </div>
                    </div>

                    <!-- Role -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-id-badge"></i> Role
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-id-badge field-icon"></i>
                            <input type="text"
                                   class="form-ctrl"
                                   id="role"
                                   value="examiner"
                                   readonly />
                        </div>
                    </div>

                    <!-- Center Code -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-building"></i> Center Code
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-building field-icon"></i>
                            <input type="text"
                                   class="form-ctrl"
                                   id="centerCode"
                                   placeholder="Enter center code"
                                   required />
                        </div>
                    </div>

                </div>

                <hr class="section-divider" />

                <!-- ══ Academic Information ══ -->
                <div class="section-title">Academic Information</div>

                <div class="form-grid">

                    <!-- Session -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-calendar"></i> Session
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-calendar field-icon"></i>
                            <select class="form-sel" id="sessionId">
                                <option value="">Select Session</option>
                            </select>
                        </div>
                    </div>

                    <!-- Program -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-graduation-cap"></i> Program
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-graduation-cap field-icon"></i>
                            <select class="form-sel" id="programId">
                                <option value="">Select Program</option>
                            </select>
                        </div>
                    </div>

                    <!-- Course -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-book"></i> Course
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-book field-icon"></i>
                            <select class="form-sel" id="courseId">
                                <option value="">Select Course</option>
                            </select>
                        </div>
                    </div>

                    <!-- Semester -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-layer-group"></i> Semester
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-layer-group field-icon"></i>
                            <select class="form-sel" id="semester">
                                <option value="">Select Semester</option>
                            </select>
                        </div>
                    </div>

                    <!-- Subject -->
                    <div class="field-wrap">
                        <label class="form-label">
                            <i class="fa fa-file-alt"></i> Subject
                        </label>
                        <div class="input-icon-wrap">
                            <i class="fa fa-file-alt field-icon"></i>
                            <select class="form-sel" id="subjectId">
                                <option value="">Select Subject</option>
                            </select>
                        </div>
                    </div>

                </div>

                <!-- Submit -->
                <div>
                    <button type="submit" class="btn-register">
                        <i class="fa fa-user-plus"></i>
                        &nbsp; Register Examiner
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<script>
    $(document).ready(function () {
        loadPrograms();
        loadSession();
    });

    function loadSession() {
        $.get(ApiBaseUrl + 'Course/GetSession', function (res) {
            let session = '<option value="">Select Session</option>';
            res.forEach(x => {
                session += `<option value="${x.sessionId}">${x.sessionName}</option>`;
            });
            $('#sessionId').html(session);
        });
    }

    function loadPrograms() {
        $.get(ApiBaseUrl + 'Course/GetPrograms', function (res) {
            let opt = '<option value="">Select Program</option>';
            res.forEach(x => {
                opt += `<option value="${x.programId}">${x.programName}</option>`;
            });
            $('#programId').html(opt);
        });
    }

    document.getElementById("programId").addEventListener("change", function () {
        let programId = this.value;
        $("#courseId").val('');
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/courses/${programId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("courseId");
                courseDropdown.innerHTML = '<option value="">Select Course</option>';
                data.forEach(item => {
                    courseDropdown.innerHTML += `<option value="${item.course_Id}">${item.course_Name}</option>`;
                });
            });
    });

    document.getElementById("courseId").addEventListener("change", function () {
        let courseId = this.value;
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/semester/${courseId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("semester");
                courseDropdown.innerHTML = '<option value="">Select Semester</option>';
                data.forEach(item => {
                    courseDropdown.innerHTML += `<option value="${item.semesterId}">${item.semesterName}</option>`;
                });
            });
    });

    document.getElementById("semester").addEventListener("change", function () {
        let semId = this.value;
        let courseId = $("#courseId").val();
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/getsubject/${semId}/${courseId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("subjectId");
                courseDropdown.innerHTML = '<option value="">Select subject</option>';
                data.forEach(item => {
                    courseDropdown.innerHTML += `<option value="${item.subjectId}">${item.subjectName}</option>`;
                });
            });
    });

    $("#registerForm").submit(function (e) {
        e.preventDefault();
        var model = {
            username: $("#username").val(),
            email: $("#email").val(),
            mobile: $("#mobile").val(),
            role: $("#role").val(),
            programId: $("#programId").val(),
            courseId: $("#courseId").val(),
            semesterId: $("#semester").val(),
            subjectId: $("#subjectId").val(),
            centerCode: $("#centerCode").val()
        };
        $.ajax({
            url: ApiBaseUrl + 'Examiner/register',
            type: 'POST',
            data: JSON.stringify(model),
            contentType: 'application/json',
            success: function (res) {
                $("#msg").html(`<div class="alert alert-success">${res.message}</div>`);
                $("#registerForm")[0].reset();
            },
            error: function (err) {
                $("#msg").html(`<div class="alert alert-danger">${err.responseJSON.message}</div>`);
            }
        });
    });
</script>