    <script>

        document.addEventListener("DOMContentLoaded", function ()
        {
            var successMessage = document.getElementById("successMessage");
            var errorMessage = document.getElementById("errorMessage");
            function handleMessage(messageElement, shouldRefresh) {
                if (messageElement) {
                    if (!sessionStorage.getItem("messageShown")) {
                        sessionStorage.setItem("messageShown", "true");
                        setTimeout(function () {
                            messageElement.classList.add("fade-out");
                            setTimeout(function () {
                                sessionStorage.removeItem("messageShown");
                                if (shouldRefresh) {
                                    window.location.href = window.location.pathname;
                                }                        }, 500);
                        }, 2000);
                        } else {
                            sessionStorage.removeItem("messageShown");
                            messageElement.style.display = "none";
                        }
                        }
                        }
                        handleMessage(successMessage, true);
                        handleMessage(errorMessage, false);
                    });
    </script>
    <script>
        let current = 1;
        const total = 4;
        function goTo(n) {
            if (n < 1 || n > total) return;
            document.getElementById('panel-' + current).classList.remove('active');
            for (let i = 1; i <= total; i++) {
                const c = document.getElementById('s' + i);
                if (i < n)       c.className = 'step-circle done';
                else if (i === n) c.className = 'step-circle active';
                else              c.className = 'step-circle';
                if (i < total) {
                    const l = document.getElementById('l' + i);
                    l.className = i < n ? 'step-line done' : 'step-line';
                }
            }
            current = n;
            document.getElementById('panel-' + current).classList.add('active');
            document.getElementById('cur').textContent = current;
            document.getElementById('btn-prev').style.visibility = current === 1 ? 'hidden' : 'visible';
            document.getElementById('btn-next').style.display    = current === total ? 'none' : '';
            document.getElementById('btn-submit').style.display  = current === total ? '' : 'none';
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function navigate(dir) { goTo(current + dir); }
        document.addEventListener('DOMContentLoaded', function () {
            const hasErrors = document.querySelectorAll('.field-error:not(:empty)').length > 0;
            if (hasErrors) {
                for (let i = 1; i <= total; i++) {
                    document.getElementById('panel-' + i).classList.add('active');
                }
                document.getElementById('btn-prev').style.visibility = 'hidden';
                document.getElementById('btn-next').style.display = 'none';
                document.getElementById('btn-submit').style.display = '';
            }
        });
    </script>
