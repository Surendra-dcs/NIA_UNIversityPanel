</div>


<script>
      $(document).ready(function () {
        $('#examTable').DataTable({
            ajax: {
                url: ApiBaseUrl + 'Exam/resultlist',
                dataSrc: ''
            },
            columns: [
                {
                    data: null,
                    render: (data, type, row, meta) =>
                        meta.row + meta.settings._iDisplayStart + 1
                },
                { data: 'rollNumber' },
                { data: 'examName' },
                { data: 'userName' },
                { data: 'email' },
                { data: 'attempt' },
                { data: 'resultStatus' },
                 { data: 'fallinpaper' }
            ]
        });
         loadPrograms();
    });
     function closeModal() {
        $('#examModal').hide();
    }
    function openExamModal() {
     $("#examId").val(0);
     $("#examName").val('');
     $("#status").val('');
     $("#programDropdown").val('');
     $("#courseDropdown").val('');
     $('#examModal').css('display', 'flex');
    }



    $('#statusFilter').on('change', function () {
        var table = $('#examTable').DataTable();
        table.column(4).search(this.value).draw();
    });
</script>

