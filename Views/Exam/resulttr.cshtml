
@{
    ViewData["Title"] = "resulttr";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}


<link href="~/css/programandcourse.css" rel="stylesheet" />
<style>
    .Filters {
        display: flex;
        justify-content: space-evenly;
        padding: 10px 0px 0;
    }

    select#examFilter{
        padding: 5px;
        background: #dfdfdf;
        border-radius: 3px;
    }

    input#rollFilter {
        padding: 5px;
        background: #dfdfdf;
        border-radius: 3px;
    }
</style>

<style>
 





  .page {
    width: 297mm;
    min-height: 210mm;
    margin: 10mm auto;
    background: #fff;
    padding: 5mm 6mm;
    box-shadow: 0 0 8px rgba(0,0,0,0.3);
    position: relative;
  }

  /* ── TOP BAR ── */
  .top-bar {
    display: flex;
    justify-content: space-between;
    font-size: 9.5px;
    margin-bottom: 3px;
    color: #333;
  }

  /* ── HEADER ── */
  .header {
    display: flex;
    align-items: center;
    margin-bottom: 3px;
    padding: 5px;
  }

  .logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    flex-shrink: 0;
    margin-left: 30px;
  }

  .header-center {
    flex: 1;
    text-align: center;
  }

  .header-center .h1 {
    font-size: 17px;
    font-weight: bold;
    color: #000;
    letter-spacing: 0.3px;
  }

  .header-center .h2 { font-size: 11px; margin-top: 1px; }
  .header-center .h3 { font-size: 11px; }
  .header-center .h4 { font-size: 11px; }

  .header-center .exam-title {
    font-size: 12px;
    font-weight: bold;
    margin-top: 4px;
  }

  .header-center .tab-title {
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 0.5px;
    margin-top: 2px;
  }

  .page-box {
    border: 1.5px solid #000;
    padding: 2px 10px;
    font-size: 12px;
    font-weight: bold;
    align-self: flex-start;
    white-space: nowrap;
    padding: 2px 30px;
  }

  .date-issue {
    font-size: 11px;
    font-weight: bold;
    text-align: right;
    margin-top: 2px;
     margin-right:10px;
    white-space: nowrap;
    
    
  }

  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 40px;
    position: relative;
  }

  /* ── MAIN TABLE ── */
  .main-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 10px;
    margin-top: 4px;
  }

  .main-table th, .main-table td {
    border: 1px solid #000;
    padding: 2px 3px;
    vertical-align: middle;
    text-align: center;
  }
  

  /* Header row 1 - top labels */
  .th-sno     { width: 22px; }
  .th-info    { width: 110px; }
  .th-attempt { width: 22px; }
  .th-subject { }
  .th-ucode   { width: 58px; }
  .th-marks-scheme { width: 80px; }
  .th-obtained     { width: 130px; }
  .th-grace        { width: 30px; }
  .th-reqd         { width: 42px; }
  .th-dist         { width: 30px; }
  .th-grand        { width: 38px; }
  .th-result       { width: 36px; }

  /* Rotated text */
  .rotated {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
    font-size: 9.5px;
    font-weight: bold;
    padding: 4px 1px;
    line-height: 1.2;
  }

  /* Candidate info cell - left aligned */
  .info-cell {
    text-align: left;
    vertical-align: middle;
    font-size: 10px;
    line-height: 1.6;
    padding: 3px 5px;
  }

  .info-cell .roll    { font-weight: bold; font-size: 11px; }
  .info-cell .enroll  { font-size: 10px; }
  .info-cell .name    { font-weight: bold; font-size: 10px; }
  .info-cell .father  { font-size: 10px; }

  /* Subject name cell */
  .subj-cell {
    
    padding: 2px 5px;
    font-size: 10px;
    white-space: nowrap;
    text-align: left ! important;
  }

  /* Data cells */
  .num { font-size: 10px; }
  .dash { font-size: 12px; }

  /* Notes section */
  .notes-row td {
    border: 1px solid #000;
    vertical-align: top;
    padding: 4px 6px;
    font-size: 10px;
  }

  .notes-content { width: 55%; }
  .notes-sign    { width: 45%; }

  .note-title { font-weight: bold; margin-bottom: 2px; font-size: 10px; }
  .note-item  { margin: 1px 0; font-size: 10px; line-height: 1.4; }

  .sign-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: 6px;
    font-size: 10px;
    font-weight: bold;
  }

  .sign-col { text-align: center; }


  /* Thick border for outer table */
  .main-table { border: 1.5px solid #000; }

  /* Sub-header rows */
  .subhdr th {
    font-size: 9.5px;
    background: #fff;
    font-weight: bold;
    padding: 2px 2px;
  }
</style>
