                        <td>80</td>
                        <td colspan="2">80</td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>

                    <!-- NOTES ROW -->
                    <tr>
                        <td colspan="4" class="notes-content" style="vertical-align:top; padding:5px 7px; font-size:10px; text-align:left; border:1px solid #000;">
