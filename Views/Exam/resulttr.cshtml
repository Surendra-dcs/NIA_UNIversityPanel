@{
    ViewData["Title"] = "Result";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<link href="~/css/tabularresult.css" rel="stylesheet" />
<script src="~/js/printtr.js"></script>
<style>
    .search-panel {
        background: #fff;
        border: 1px solid #dcdcdc;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

    .search-title {
        font-size: 20px;
        font-weight: 600;
        color: #0d3b66;
        margin-bottom: 15px;
    }

    .search-row {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: end;
    }

    .search-group {
        min-width: 220px;
        flex: 1;
    }

        .search-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .search-group select {
            width: 100%;
            height: 38px;
            border: 1px solid #ccc;
            border-radius: 5px;
            padding: 0 10px;
        }

    .btn-group {
        flex: 0;
    }

        .btn-group button {
            height: 38px;
            padding: 0 25px;
            border: none;
            background: #0d6efd;
            color: #fff;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
        }

            .btn-group button:hover {
                background: #0b5ed7;
            }
</style>
<div class="search-panel">

    <div class="search-title">
        🔍 Tabulation Register Search
    </div>

    <div class="search-row">

        <div class="search-group">
            <label>Session</label>
            <select id="sessionId">
                <option value="">Select Session</option>
            </select>
        </div>

        <div class="search-group">
            <label>Program</label>
            <select id="programId">
                <option value="">Select Program</option>
            </select>
        </div>

        <div class="search-group">
            <label>Course</label>
            <select id="courseId">
                <option value="">Select Course</option>
            </select>
        </div>

        <div class="search-group">
            <label>Semester</label>
            <select id="semester">
                <option value="">Select Semester</option>
            </select>
        </div>

        <div class="search-group btn-group">
            <button type="button" onclick="loadResult()">
                Search Report
            </button>
        </div>
        <button type="button" class="btn btn-success" onclick="printTable()" style="width: 98px; height: 38px; font-weight: 800; background: red; color: white;">
            🖨 Print
        </button>       
       
    </div>
</div>


 <div class="page">
        <div class="top">
            <div class="logo">
            <img src="~/Logo/nia_logo.png" />
            </div>
            <div class="heading">
                <h2>NATIONAL INSTITUTE OF AYURVEDA, JAIPUR</h2>
                <p>Deemed to be University</p>
                <p>(Ministry of AYUSH, Govt. of India)</p>
                <p>Jorawar Singh Gate, Amer Road, Jaipur-302002</p>
                <h4>
                    <span id="ExamnameId"></span>
                </h4>
                <h3>TABULATION REGISTER/LEDGER</h3>
            </div>

            <div class="page-no">Page: 1</div>
        </div>

        <div class="issue-date">Date of Issue : .....................</div>

        <table class="ledger">
            <thead>
                <tr>
                    <th rowspan="2">S.<br />No.</th>
                    <th rowspan="2">
                        Roll NO<br />Enrollment No.<br />Candidate Name<br />Father`s Name
                    </th>
                    <th rowspan="2" class="vertical vertical-col">Attempt</th>
                    <th rowspan="2" class="subject-head" style="font-size:13px">
                        Name of Subjects<br /><small>In which appearing</small>
                    </th>
                <th rowspan="2" class="unique-code" style="font-size:13px">Unique Code</th>
                <th colspan="2" class="group-head" style="font-size:13px">Marks Scheme</th>
                <th colspan="5" class="group-head" style="font-size:13px">Theory</th>
                <th colspan="4" class="group-head" style="font-size:13px">OBTAINED MARKS</th>
                    <th rowspan="2" class="vertical vertical-col no-side">
                        Required to appear at the<br />Attempt Examinations
                    </th>
                    <th rowspan="2" class="vertical vertical-col no-side">
                        Distinction-D / First Class : I
                    </th>
                    <th rowspan="2" >Grand<br />Total</th>
                    <th rowspan="2">Result</th>
                </tr>
                <tr>
                    <th>MAX</th>
                    <th>MIN</th>
                    <th class="vertical vertical-col">Marks of Evaluator I</th>
                    <th class="vertical vertical-col">Marks of Evaluator II</th>
                    <th class="vertical vertical-col">
                        Difference between Evaluator I & II
                    </th>
                    <th class="vertical vertical-col">Marks of Evaluator III</th>
                    <th class="vertical vertical-col">
                        Average of Two Higher marks among<br />three evaluator Theory I Total
                    </th>
                <th style="font-size:13px">Theory</th>
                <th style="font-size:13px">Total</th>
                    <th>Subject<br />Total</th>
                    <th>Grace</th>
                </tr>
            </thead>

        <tbody id="resultBody"></tbody>
        </table>

        <div class="footer">
            <div class="notes">
                <b>Note.</b><br />
                1. For candidate to pass, he/she shall require to obtain a minimum of
                50% marks in each of Theory examination.<br />
                2. The candidate securing 65% marks or above in a subject shall be
                declared to have obtained First Class(Denoted by I) in that
                Subject.<br />
                3. The candidate securing 75% marks or above in a subject shall be
                declared to have obtained distinction(Denoted by D)in that Subject.<br />
                4. A candidate failing in the Theory part of a paper will be
                considered fail in Theory.
            </div>

            <div class="sign">Tabulator</div>
            <div class="sign1">DCOE</div>
            <div class="sign">Controller of Examinations</div>
            <div class="sign2">Registrar</div>
            <div class="sign2">Vice Chancellor</div>
        </div>
    </div>
    <script>
        $(document).ready(function () {
        loadPrograms();
        loadSession();
        });
         function loadSession() {
           $.get(ApiBaseUrl + 'Course/GetSession', function (res) {
               let session = '<option value="">Select Session</option>';
               res.forEach(x => {
                   session += `<option value="${x.sessionId}">${x.sessionName}</option>`;
               });
               $('#sessionId').html(session);
           });
         }
         function loadPrograms() {
           $.get(ApiBaseUrl + 'Course/GetPrograms', function (res) {
               let opt = '<option value="">Select Program</option>';
               res.forEach(x => {
                   opt += `<option value="${x.programId}">${x.programName}</option>`;
               });
               $('#programId').html(opt);
           });
         }
         document.getElementById("programId").addEventListener("change", function () {
        let programId = this.value;
        $("#courseId").val('');
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/courses/${programId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("courseId");
                courseDropdown.innerHTML = '<option value="">Select Course</option>';                   
                data.forEach(item => {
                     courseDropdown.innerHTML += `<option value="${item.course_Id}">${item.course_Name}</option>`;
                });
            });
     });
       document.getElementById("courseId").addEventListener("change", function () {
        let courseId = this.value;
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/semester/${courseId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("semester");
                courseDropdown.innerHTML = '<option value="">Select Semester</option>';
                data.forEach(item => {
                     courseDropdown.innerHTML += `<option value="${item.semesterId}">${item.semesterName}</option>`;
                });
            });
     });

        async function loadResult() {
        const courseId = $("#courseId").val();
        const semester = $("#semester").val();
        const sessionId = $("#sessionId").val();

        const response = await fetch(
            ApiBaseUrl + `Result/GetTabulationRegisterResultReport?courseId=${courseId}&semester=${semester}&sessionId=${sessionId}`
        );

       const data = await response.json();
           if (!data || data.length === 0) {
              $("#ExamnameId").text('');
              $("#resultBody").html('');
              alert("No records found for the selected Session, Course and Semester.");
              return;
           }
       if (data && data.length > 0) {
       $("#ExamnameId").text(data[0].examname || '');
       } else {
           $("#ExamnameId").text('');
       }
        let grouped = {};
        data.forEach(item => {
            let key = item.rollNumber;
            if (!grouped[key]) {
                grouped[key] = [];
            }
            grouped[key].push(item);
        });

        let html = '';
        let sno = 1;

        Object.keys(grouped).forEach(key => {
            let student = grouped[key];
            let first = student[0];
            html += `
            <tr>
                <td>${sno++}</td>
                <td>
                    ${first.rollNumber}
                    <hr/>
                    ${first.enrollmentNumber}
                    <hr/>
                    ${first.candidateName}
                    <hr/>
                    ${first.fatherName}
                </td>
                <td>${first.attempt}</td>

                <td class="s1">
                ${student.map(x => `${x.subject_code} - ${x.subject_name}`).join('<br>')}
               </td>

                <td>
                    ${student.map(x => x.scriptId).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.maxMarks).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.minMarks).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.evaluator1).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.evaluator2).join('<br>')}
                </td>
                <td>
                   ${student.map(x =>
                       x.difference12 != null
                           ? Number(x.difference12).toFixed(2)
                           : '0.00'
                   ).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.evaluator3).join('<br>')}
                </td>
                 <td>
                 ${student.map(x =>
                     x.averageOfTwoHigherMarks != null
                         ? Number(x.averageOfTwoHigherMarks).toFixed(2)
                         : '0.00'
                 ).join('<br>')}
               </td>
                    <td>
                    ${student.map(x => x.total).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.total).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.subjectTotal).join('<br>')}
                </td>
                <td>
                    ${student.map(x => x.graceMarks).join('<br>')}
                </td>
                <td>
                    ${student
                        .filter(x => x.required_To_Appear)
                        .map(x => x.required_To_Appear)
                        .join('<br>')}
                </td>

                <td>
                    ${student
                        .filter(x => x.distinction)
                        .map(x => x.distinction)
                        .join('<br>')}
                </td>

                <td>${first.grandTotal}</td>

                <td>${first.result}</td>
            </tr>`;
        });

        $("#resultBody").html(html);
    }
      

</script>

