@{
    ViewData["Title"] = "Result For CSV&Excel";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<script src="~/js/printdepartmentwisereports.js"></script>
<style>
    .search-panel {
        background: #fff;
        border: 1px solid #dcdcdc;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

    .search-title {
        font-size: 20px;
        font-weight: 600;
        color: #0d3b66;
        margin-bottom: 15px;
    }

    .search-row {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        align-items: end;
    }

    .search-group {
        min-width: 220px;
        flex: 1;
    }

        .search-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .search-group select {
            width: 100%;
            height: 38px;
            border: 1px solid #ccc;
            border-radius: 5px;
            padding: 0 10px;
        }

    .btn-group {
        flex: 0;
    }

        .btn-group button {
            height: 38px;
            padding: 0 25px;
            border: none;
            background: #0d6efd;
            color: #fff;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
        }

            .btn-group button:hover {
                background: #0b5ed7;
            }

    .download-btn:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

    .search-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
    }

    .print-page {
        position: relative;
        page-break-after: always;
        min-height: 190mm;
    }

        .print-page:last-child {
            page-break-after: auto;
        }

</style>
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
        background: #f4f6f9;
        padding: 20px;
        color: #222;
    }

    .page {
        width: 100%;
        max-width: 1400px;
        margin: auto;
        background: #fff;
        padding: 25px;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }

    /* ================= HEADER ================= */

    .top {
        display: flex;
        align-items: center;
        gap: 20px;
        border-bottom: 3px solid #0d6efd;
        padding-bottom: 15px;
        margin-bottom: 20px;
    }

    .logo img {
        width: 90px;
        height: 90px;
        object-fit: contain;
    }

    .heading {
        flex: 1;
        text-align: center;
    }

        .heading h2 {
            font-size: 28px;
            color: #0d3b66;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .heading p {
            font-size: 14px;
            color: #555;
            margin-bottom: 2px;
        }

        .heading h4 {
            margin-top: 10px;
            font-size: 18px;
            color: #c1121f;
            font-weight: 700;
        }

        .heading h3 {
            margin-top: 8px;
            font-size: 20px;
            background: #0d6efd;
            color: white;
            display: inline-block;
            padding: 8px 18px;
            border-radius: 5px;
            letter-spacing: 1px;
        }

    /* ================= TABLE ================= */

    .table-responsive {
        width: 100%;
        overflow-x: auto;
    }

    .ledger {
        width: 100%;
        border-collapse: collapse;
        min-width: 1100px;
    }

        .ledger thead th {
            background: #0d3b66;
            color: #fff;
            padding: 12px 10px;
            font-size: 14px;
            border: 1px solid #dcdcdc;
            text-align: center;
            position: sticky;
            top: 0;
            z-index: 1;
        }

        .ledger tbody td {
            border: 1px solid #ddd;
            padding: 10px;
            font-size: 14px;
            text-align: center;
        }

        .ledger tbody tr:nth-child(even) {
            background: #f8fbff;
        }

        .ledger tbody tr:hover {
            background: #eef5ff;
            transition: 0.3s;
        }

    /* Result Badge */

    .pass {
        color: #198754;
        font-weight: bold;
    }

    .fail {
        color: #dc3545;
        font-weight: bold;
    }

    /* ================= MOBILE ================= */

    @@media(max-width:768px) {
        body

    {
        padding: 10px;
    }

    .page {
        padding: 15px;
    }

    .top {
        flex-direction: column;
        text-align: center;
    }

    .logo img {
        width: 70px;
        height: 70px;
    }

    .heading h2 {
        font-size: 20px;
    }

    .heading h3 {
        font-size: 16px;
        padding: 6px 12px;
    }

    .heading h4 {
        font-size: 15px;
    }

    .ledger thead th,
    .ledger tbody td {
        padding: 8px;
        font-size: 12px;
    }

    }

    /* ================= PRINT ================= */

    @@media print {

        body {
            background: white;
            padding: 0;
        }

        .page {
            box-shadow: none;
            border-radius: 0;
            padding: 0;
        }

        .ledger thead th {
            background: #d9d9d9 !important;
            color: black !important;
        }
    }
</style>

<div class="search-panel">

    <div class="search-title">
        🔍 Result Sheet Download (CSV & Excel)        
    </div>

    <div class="search-row">
        <div class="search-group">
            <label>Session</label>
            <select id="sessionId">
                <option value="">Select Session</option>
            </select>
        </div>

        <div class="search-group">
            <label>Program</label>
            <select id="programId">
                <option value="">Select Program</option>
            </select>
        </div>

        <div class="search-group">
            <label>Course</label>
            <select id="courseId">
                <option value="">Select Course</option>
            </select>
        </div>

        <div class="search-group">
            <label>Semester</label>
            <select id="semester">
                <option value="">Select Semester</option>
            </select>
        </div>

        <div class="search-group">
            <label>Download Type</label>
            <select id="downloadType">
                <option value="">Select Type</option>
                <option value="excel">Excel</option>
                <option value="csv">CSV</option>
            </select>
        </div>

        

        <div class="search-group btn-group">
            <button type="button" onclick="downloadResult()">
                Download
            </button>           
        </div>
    
       
    </div>
</div>

    <script>
        $(document).ready(function () {
        loadPrograms();
        loadSession();       
        });
         function loadSession() {
           $.get(ApiBaseUrl + 'Course/GetSession', function (res) {
               let session = '<option value="">Select Session</option>';
               res.forEach(x => {
                   session += `<option value="${x.sessionId}">${x.sessionName}</option>`;
               });
               $('#sessionId').html(session);
           });
         }
         function loadPrograms() {
           $.get(ApiBaseUrl + 'Course/GetPrograms', function (res) {
               let opt = '<option value="">Select Program</option>';
               res.forEach(x => {
                   opt += `<option value="${x.programId}">${x.programName}</option>`;
               });
               $('#programId').html(opt);
           });
         }
         document.getElementById("programId").addEventListener("change", function () {
        let programId = this.value;
        $("#courseId").val('');
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/courses/${programId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("courseId");
                courseDropdown.innerHTML = '<option value="">Select Course</option>';                   
                data.forEach(item => {
                     courseDropdown.innerHTML += `<option value="${item.course_Id}">${item.course_Name}</option>`;
                });
            });
     });
       document.getElementById("courseId").addEventListener("change", function () {
        let courseId = this.value;
        $("#semester").val('');
        $("#subjectId").val('');
        fetch(ApiBaseUrl + `Subject/semester/${courseId}`)
            .then(res => res.json())
            .then(data => {
                let courseDropdown = document.getElementById("semester");
                courseDropdown.innerHTML = '<option value="">Select Semester</option>';
                data.forEach(item => {
                     courseDropdown.innerHTML += `<option value="${item.semesterId}">${item.semesterName}</option>`;
                });
            });
     });

       function downloadResult() {
           if($("#courseId").val()=="")
           {
            alert("Please select Course.");
            return;
           }
           if($("#semester").val()=="")
           {
            alert("Please select Semester.");
            return;
           }
           if($("#sessionId").val()=="")
           {
            alert("Please select Session.");
            return;
           }
           if($("#downloadType").val()=="")
           {
            alert("Please select Session.");
            return;
           }          

        const courseId = parseInt($("#courseId").val())
        const semester = parseInt($("#semester").val())
        const sessionId = parseInt($("#sessionId").val())
        const downloadType = $("#downloadType").val();       
        window.location =
            ApiBaseUrl +`Result/DownloadResult?courseId=${courseId}&semester=${semester}&sessionId=${sessionId}&downloadType=${downloadType}`;
    }      

</script>

