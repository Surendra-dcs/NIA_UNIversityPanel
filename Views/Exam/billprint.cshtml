
@{
    ViewData["Title"] = "billprint";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />

<style>
    .page {
        width: 210mm;
        height: 297mm;
        background: white;
        margin: 10px 0;
        page-break-after: always;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

    @@media print {
        body{
            background: none;
        }

    .page {
        box-shadow: none;
        margin: 0;
        page-break-after: always;
    }

    }

    /* ===== PAGE WRAPPER ===== */
    .page {
        background: #ffffff;
        width: 210mm;
        height: 297mm;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
    }

    /* ============================================================
               PAGE 1 — NIA OFFICE ORDER (REMUNERATION)
               ============================================================ */
    .page-1 {
        padding: 6mm 12mm 4mm 12mm;
    }

    /* ===== HEADER ===== */
    .p1-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 5px;
        margin-bottom: 3px;
    }

    .p1-logo-box {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .p1-logo-box img {
            display: block;
            width: 100px;
            height: 100px;
            object-fit: contain;
        }

    .p1-header-center {
        flex: 1;
        text-align: center;
        padding: 0 8px;
    }

    .p1-hindi-title {
        font-size: 30px;
        font-weight: 700;
        color: #000;
        line-height: 1.2;
    }

    .p1-hindi-subtitle {
        font-size: 15px;
        font-weight: 400;
        color: #222;
        margin-top: 1px;
        line-height: 1.3;
    }

    .p1-eng-title {
        font-size: 20px;
        font-weight: 700;
        color: #000;
        margin-top: 3px;
        letter-spacing: 0.3px;
    }

    .p1-eng-subtitle {
        font-size: 13px;
        color: #222;
        margin-top: 1px;
        line-height: 1.35;
        font-weight: 600;
    }

    .p1-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        font-size: 12px;
        color: #111;
        margin: 4px 0 5px 0;
        line-height: 1.3;
    }

    .p1-meta-date {
        text-align: right;
        font-size: 12px;
        line-height: 1.4;
    }

    .p1-doc-title {
        text-align: center;
        font-size: 16px;
        font-weight: 700;
        text-decoration: underline;
        margin-bottom: 5px;
        color: #000;
        letter-spacing: 0.3px;
    }

    .p1-intro {
        font-size: 13px;
        line-height: 1.45;
        margin-bottom: 6px;
        color: #111;
        text-align: justify;
    }

    .p1-main-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
    }

        .p1-main-table th,
        .p1-main-table td {
            border: 1px solid #000;
            padding: 2px 5px;
            vertical-align: top;
            line-height: 1.3;
            font-size: 11px;
        }

        .p1-main-table thead th {
            background-color: #f2f2f2;
            text-align: center;
            font-weight: 700;
            padding: 4px 5px;
            font-size: 12px;
        }

        .p1-main-table td:first-child {
            width: 8%;
            text-align: center;
            font-weight: 700;
        }

        .p1-main-table td:nth-child(2) {
            width: 62%;
        }

        .p1-main-table td:nth-child(3) {
            width: 30%;
            text-align: right;
            padding-right: 8px;
            white-space: nowrap;
        }

        .p1-main-table h1 {
            font-size: 12px;
            margin-bottom: 2px;
            font-weight: 700;
            line-height: 1.25;
        }

        .p1-main-table p {
            margin: 1px 0;
            padding-left: 8px;
            line-height: 1.25;
            font-size: 11px;
        }

    .p1-signature-area {
        height: 20px;
    }

    .p1-footer-address {
        border-top: 1px solid #aaa;
        padding-top: 4px;
        text-align: center;
        font-size: 11px;
        color: #222;
        line-height: 1.55;
    }

    .p1-footer-hindi {
        font-size: 13px;
    }

    .p1-footer-address a {
        color: #000;
        text-decoration: none;
    }

    .p1-page-bottom-bar {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        color: #555;
        margin-top: 4px;
    }

    /* ============================================================
               PAGE 2 — NIA REMUNERATION VOUCHER
               ============================================================ */
    .page-2 {
        padding: 6mm 20mm 4mm 20mm;
        font-size: 10px;
        line-height: 1.15;
        place-self: anchor-center;
    }

    .p2-top-meta {
        display: flex;
        justify-content: flex-end;
        align-items: flex-start;
        margin-bottom: 4px;
    }

    .p2-voucher-block {
        text-align: right;
        line-height: 1.3;
    }

    .p2-voucher-label {
        font-weight: bold;
        font-size: 11px;
        display: flex;
        align-items: center;
        gap: 4px;
        justify-content: flex-end;
    }

    .p2-voucher-blank {
        display: inline-block;
        width: 85px;
        border-bottom: 1.5px dotted #000;
        height: 14px;
    }

    .p2-office-use {
        font-size: 9px;
        font-style: normal;
        color: #555;
        text-align: right;
    }

    .p2-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        padding-bottom: 8px;
        margin-bottom: 6px;
    }

    .p2-logo {
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .p2-logo img {
            width: 100px;
            height: 80px;
            object-fit: contain;
            margin-right: 160px;
        }

    .p2-heading {
        text-align: center;
        line-height: 1.25;
    }

        .p2-heading h1 {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 0.6px;
            color: #1a1a1a;
        }

        .p2-heading p {
            font-size: 14px;
            margin: 1px 0;
            color: #333;
            font-weight: 600;
        }

    .p2-bank-section {
        margin: 4px 0;
        padding: 3px 2px;
    }

    .p2-bank-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 4px;
        gap: 150px;
    }

    .p2-bank-field {
        display: flex;
        align-items: center;
        flex: 1;
    }

    .p2-bank-field-label {
        white-space: nowrap;
        margin-right: 6px;
        font-weight: 400;
        font-size: 12px;
        min-width: 80px;
    }

    .p2-bank-field-line {
        flex: 1;
        border-bottom: 1.5px dotted #000;
        height: 14px;
        min-width: 10px;
    }

    .p2-form-title {
        text-align: center;
        font-weight: bold;
        font-size: 11px;
        text-decoration: underline;
        text-transform: uppercase;
        margin: 4px 0 6px 0;
        line-height: 1.3;
        letter-spacing: 0.4px;
        padding: 3px 4px;
    }

    .p2-form-row {
        display: flex;
        align-items: center;
        width: 100%;
        gap: 0;
        margin-bottom: 3px;
        font-size: 11px;
        font-weight: 600;
    }

    .p2-form-row-label {
        white-space: nowrap;
        font-weight: 400;
        font-size: 12px;
        padding-right: 6px;
        flex-shrink: 0;
    }

    .p2-form-row-line {
        flex: 1 1 0%;
        min-width: 0;
        border-bottom: 1.5px dotted #000;
        height: 16px;
    }

    .p2-form-group {
        display: flex;
        align-items: center;
        margin-bottom: 4px;
        font-size: 12px;
        font-weight: 400;
        gap: 6px;
        width: 100%;
    }

    .p2-fg-label {
        white-space: nowrap;
        font-weight: 400;
        min-width: 60px;
        font-size: 12px;
        flex-shrink: 0;
    }

    .p2-fg-line-solid {
        flex: 1 1 0%;
        border-bottom: 1.5px dotted #000;
        height: 14px;
        min-width: 0;
    }

    .p2-fg-note {
        font-size: 9.5px;
        font-style: normal;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .p2-fg-hint {
        font-size: 9.5px;
        margin-bottom: 3px;
    }

    .p2-addr-row {
        display: flex;
        gap: 6px;
        align-items: center;
        width: 100%;
        font-size: 11px;
        margin-bottom: 3px;
    }

    .p2-addr-label {
        white-space: nowrap;
        font-weight: 400;
        flex-shrink: 0;
    }

    .p2-addr-line-sm {
        border-bottom: 1px dotted #000;
        height: 14px;
        width: 90px;
        flex-shrink: 0;
    }

    .p2-addr-line-pin {
        border-bottom: 1px dotted #000;
        height: 14px;
        width: 60px;
        flex-shrink: 0;
    }

    .p2-examiner-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        margin: 3px 0 3px 0;
        font-size: 12px;
    }

    .p2-ex-item {
        display: flex;
        align-items: center;
        font-size: 12px;
        font-weight: 400;
        gap: 4px;
    }

    .p2-ex-line {
        border-bottom: 1px dotted #000;
        height: 14px;
        width: 90px;
        flex-shrink: 0;
    }

    .p2-ex-line-sm {
        border-bottom: 1px dotted #000;
        height: 14px;
        width: 40px;
        flex-shrink: 0;
    }

    .p2-main-table {
        width: 100%;
        border-collapse: collapse;
        margin: 6px 0;
        font-size: 8px;
        table-layout: fixed;
    }

    .Remuneration-for {
        border-bottom: 0.5px solid #000;
        padding-bottom: 5px;
    }

    .p2-main-table th,
    .p2-main-table td {
        border: 0.5px solid #000;
        vertical-align: top;
        line-height: 1.2;
        word-wrap: break-word;
    }

    .p2-main-table thead th {
        font-weight: 400;
        font-size: 9px;
        padding-top: 3px;
        text-transform: uppercase;
        letter-spacing: 0.2px;
    }

        .p2-main-table thead th span {
            font-size: 8.5px;
            font-weight: 600;
        }

    .p2-th-sno {
        width: 8%;
    }

    .p2-th-remuneration {
        border: 8px solid yellow;
        width: 22%;
    }

    .p2-th-setting {
        width: 10%;
    }

    .p2-th-evaluate {
        width: 12%;
    }

    .p2-th-conducting {
        width: 31%;
    }

    .p2-th-rate {
        width: 6%;
    }

    .p2-th-amount {
        width: 7%;
    }

    .p2-th-remarks {
        width: 9%;
    }

    .p2-row-blank td {
        height: 44px;
    }

    .p2-row-net td {
        height: 16px;
        font-size: 11px;
        font-weight: bold;
        text-align: right;
        padding-right: 10px;
    }

    .p2-row-words td {
        height: 16px;
        font-size: 11px;
        text-align: left;
        padding-left: 10px;
    }

    .p2-signature-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 16px;
        min-height: 58px;
    }

    .p2-sig-officer-box {
        flex: 1;
        display: flex;
        align-items: flex-end;
    }

    .p2-sig-officer-label {
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 15px;
        letter-spacing: 0.3px;
    }

    .p2-sig-examiner-box {
        width: 220px;
        text-align: center;
        font-size: 13px;
        line-height: 1.35;
    }

    .p2-sig-line {
        width: 160px;
        margin: 6px auto 3px;
        border-bottom: 1.5px solid #000;
        height: 14px;
    }

    .p2-sig-small {
        font-size: 9.5px;
        color: #555;
    }

    .p2-sig-received {
        display: block;
        margin-top: 1px;
        font-size: 13px;
        font-weight: 700;
    }

    .p2-footer {
        font-size: 11px;
        border-top: 2px solid #000;
    }

    .p2-footer-section-title {
        text-align: center;
        font-weight: bold;
        font-size: 12px;
        text-decoration: underline;
        text-transform: uppercase;
        margin: 3px 0 5px 0;
        letter-spacing: 0.4px;
    }

    .p2-footer-para {
        font-size: 12px;
        margin-bottom: 5px;
        line-height: 1.4;
    }

    .p2-footer-inline-line {
        display: inline-block;
        border-bottom: 1.5px dotted #000;
        width: 150px;
        height: 12px;
        vertical-align: bottom;
        margin: 0 4px;
    }

    .p2-footer-wide-line {
        display: inline-block;
        border-bottom: 1.5px dotted #000;
        width: 180px;
        height: 12px;
        vertical-align: bottom;
        margin: 0 4px;
    }

    .p2-footer-label-bold {
        font-weight: 400;
    }

    .p2-footer-controller {
        font-weight: 400;
        font-size: 13px;
        padding-bottom: 20px;
        margin: 30px 0 0 0;
        border-bottom: 2px solid #000;
    }

    .p2-bottom-box {
        width: 100%;
        padding: 8px 6px 2px;
    }

    .p2-bottom-top-center {
        text-align: center;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 16px;
    }

    .p2-bottom-left {
        font-size: 11px;
        margin-bottom: 16px;
    }

    .p2-bottom-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        font-size: 11px;
    }

    .p2-bottom-center {
        text-align: center;
        font-size: 12px;
        flex: 1;
    }

    .p2-bottom-right {
        min-width: 200px;
        text-align: right;
        font-size: 12px;
    }

    /* ===== PRINT ===== */
    @@media print {
        body {
            background: none;
            padding: 0;
            gap: 0;
        }

        .page {
            box-shadow: none;
            width: 210mm;
            height: 297mm;
            overflow: hidden;
        }

        .page-1 {
            page-break-after: always;
        }

        .page-2 {
            page-break-before: always;
        }
    }
</style>

<div class="table-card">
    <div class="table-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h3 class="table-title">Bulk QP Bills</h3>

        <button onclick="printBill()"
                style="padding:8px 16px; background:#007bff; color:#fff; border:none; border-radius:4px; cursor:pointer;">
            🖨 Print
        </button>
    </div>
    <!-- ✅ WHERE ALL GENERATED PAGES WILL COME -->
    <div id="printContainer"></div>

    <!-- ✅ TEMPLATE (PUT YOUR FULL 1200 LINE HTML HERE) -->
    <template id="billTemplate">

        <!-- ===== PAGE 2 ===== -->
        <div class="page page-2">

            <!-- TOP META -->
            <div class="p2-top-meta">
                <div class="p2-voucher-block">
                    <div class="p2-voucher-label">
                        Voucher No.
                        <span class="p2-voucher-blank"></span>
                    </div>
                    <div class="p2-office-use">(For Office Use Only)</div>
                </div>
            </div>

            <!-- HEADER -->
            <div class="p2-header">
                <div class="p2-logo">
                    <img src="~/Logo/nia_logo.png" alt="NIA Logo">
                </div>
                <div class="p2-heading">
                    <h1>NATIONAL INSTITUTE OF AYURVEDA</h1>
                    <p>Deemed To Be University (De Novo)</p>
                    <p>(Ministry of AYUSH, Govt. of India)</p>
                    <p>Jorawar Singh Gate, Amer Road, Jaipur-302002 (Raj.)</p>
                </div>
            </div>

            <!-- BANK DETAILS -->
            <div class="p2-bank-section">
                <div class="p2-bank-row">
                    <div class="p2-bank-field">
                        <span class="p2-bank-field-label">Name of Bank</span>
                        <span class="p2-bank-field-line bankName"></span>
                    </div>
                    <div class="p2-bank-field">
                        <span class="p2-bank-field-label">Mob. No.</span>
                        <span class="p2-bank-field-line mobile"></span>
                    </div>
                </div>
                <div class="p2-bank-row">
                    <div class="p2-bank-field">
                        <span class="p2-bank-field-label">Bank A/c No.</span>
                        <span class="p2-bank-field-line bankAccount"></span>
                    </div>
                    <div class="p2-bank-field">
                        <span class="p2-bank-field-label">E-Mail I.D.</span>
                        <span class="p2-bank-field-line email"></span>
                    </div>
                </div>
                <div class="p2-bank-row">
                    <div class="p2-bank-field">
                        <span class="p2-bank-field-label">IFSC Code</span>
                        <span class="p2-bank-field-line ifsc"></span>
                    </div>
                    <div class="p2-bank-field">
                        <span class="p2-bank-field-label">PAN No.</span>
                        <span class="p2-bank-field-line pan"></span>
                    </div>
                </div>
            </div>

            <!-- FORM TITLE -->
            <div class="p2-form-title">
                REMUNERATION BILL FOR SETTING QUESTION PAPER / THEORY ANSWER BOOK EVALUATION OR<br>
                RE-EVALUATION / PRACTICAL OR VIVA EXAMINATION / THESIS EVALUATION
            </div>

            <!-- NAME OF EXAMINER -->
            <div class="p2-form-group">
                <span class="p2-fg-label">Name of Examiner (as in Bank A/C)</span>
                <span class="p2-fg-line-solid name"></span>
                <span class="p2-fg-note">(IN BLOCK LETTERS)</span>
            </div>

            <!-- EXAMINER DETAILS -->
            <div class="p2-examiner-row">
                <span class="p2-fg-label">Examiner Details :</span>
                <div class="p2-ex-item">
                    <span>Qualification</span>
                    <span class="p2-ex-line"></span>
                </div>
                <div class="p2-ex-item">
                    <span>Specialization</span>
                    <span class="p2-ex-line"></span>
                </div>
                <div class="p2-ex-item">
                    <span>Teaching Exp. UG</span>
                    <span class="p2-ex-line-sm"></span>
                </div>
                <div class="p2-ex-item">
                    <span>PG</span>
                    <span class="p2-ex-line-sm"></span>
                </div>
            </div>

            <!-- COLLEGE ADDRESS -->
            <div class="p2-form-row">
                <span class="p2-form-row-label">Name of College with Address :</span>
                <span class="p2-form-row-line"></span>
            </div>
            <div class="p2-addr-row">
                <span class="p2-addr-label">City</span>
                <span class="p2-addr-line-sm"></span>
                <span class="p2-addr-label">Dist.</span>
                <span class="p2-addr-line-sm"></span>
                <span class="p2-addr-label">State</span>
                <span class="p2-addr-line-sm"></span>
                <span class="p2-addr-label">Pin</span>
                <span class="p2-addr-line-pin"></span>
            </div>

            <!-- RESIDENTIAL ADDRESS -->
            <div class="p2-form-row">
                <span class="p2-form-row-label">Residential Address :</span>
                <span class="p2-form-row-line"></span>
            </div>
            <div class="p2-addr-row">
                <span class="p2-addr-label">City</span>
                <span class="p2-addr-line-sm"></span>
                <span class="p2-addr-label">Dist.</span>
                <span class="p2-addr-line-sm"></span>
                <span class="p2-addr-label">State</span>
                <span class="p2-addr-line-sm"></span>
                <span class="p2-addr-label">Pin</span>
                <span class="p2-addr-line-pin"></span>
            </div>

            <!-- EXAMINATION DETAILS -->
            <div class="p2-form-row">
                <span class="p2-form-row-label">Name of the Examination</span>
                <span class="p2-form-row-line course"></span>
            </div>
            <div class="p2-fg-hint">(Course type BAMS/MD/MS/M.Sc./Ph.D./Diploma Certificate With Month Year)</div>

            <div class="p2-form-group">
                <span class="p2-fg-label">Subject & Paper</span>
                <span class="p2-fg-line-solid"></span>
            </div>

            <!-- MAIN TABLE -->
            <table class="p2-main-table">
                <thead>
                    <tr>
                        <th rowspan="2" class="p2-th-sno">S. No./<br>Assigned<br>Id</th>
                        <th rowspan="2" class="p2-th-remuneration">
                            <div class="Remuneration-for">Remuneration for </div>
                            <span>
                                SETTING QUESTION PAPER /<br>THEORY ANSWER BOOK<br>EVALUATION OR
                                RE-EVALUATION/<br>PRACTICAL OR VIVA / THESIS EVALUATION
                            </span>
                        </th>
                        <th rowspan="2" class="p2-th-setting">No of<br>Setting<br>Question<br>Paper</th>
                        <th rowspan="2" class="p2-th-evaluate">
                            No of<br>Evaluate<br>or Re-evaluate<br>Answer<br>book/Thesis
                        </th>
                        <th colspan="3" class="p2-th-conducting">Conducting Practical Exam Viva-Voce</th>
                        <th rowspan="2" class="p2-th-rate">Rate</th>
                        <th rowspan="2" class="p2-th-amount">Amount</th>
                        <th rowspan="2" class="p2-th-remarks">Remarks<br><span>(Postal etc.)</span></th>
                    </tr>
                    <tr>
                        <th>No of<br>Candidates<br>Registered</th>
                        <th>No of<br>Candidate<br>Absent from<br>Examination</th>
                        <th>No of<br>Actually<br>Examined</th>
                    </tr>
                </thead>
                <tbody class="tableBody"></tbody>
            </table>

            <!-- SIGNATURE SECTION -->
            <div class="p2-signature-section">
                <div class="p2-sig-officer-box">
                    <p class="p2-sig-officer-label">VERIFYING OFFICER (CDC)</p>
                </div>
