    <!-- ✅ SCRIPT -->
    <script>
        async function loadBill() {

            const userId = 1; // 🔁 change dynamically

            const res = await fetch(ApiBaseUrl + `Remuneration/GetBill`);
            const data = await res.json();

            if (!data || data.length === 0) return;

            const container = document.getElementById("printContainer");
            const template = document.getElementById("billTemplate");

            // 👉 LOOP FULL PAGE PER RECORD
            data.forEach((item, index) => {

                const clone = template.content.cloneNode(true);

                // ===== FILL HEADER =====
                clone.querySelectorAll(".name").forEach(e => e.innerText = item.name);
                clone.querySelector(".bankName").innerText = item.bankName;
                clone.querySelector(".bankAccount").innerText = item.bankAccount;
                clone.querySelector(".ifsc").innerText = item.ifscCode;
                clone.querySelector(".mobile").innerText = item.mobile;
                clone.querySelector(".email").innerText = item.email;
                clone.querySelector(".pan").innerText = item.panNo;
                clone.querySelector(".course").innerText = item.courseName;

                // ===== TABLE =====
                const tbody = clone.querySelector(".tableBody");

                tbody.innerHTML = `
                    <tr class="p2-row-blank" style="text-align: -webkit-center;">
                        <td></td>
                        <td>SETTING QUESTION PAPER</td>
                        <td>1</td>
                        <td>-</td>
                        <td>-</td>
                        <td>-</td>
                        <td>-</td>
                        <td>${item.rate}</td>
                        <td>${item.amount}</td>
                        <td></td>
                    </tr>
                    <tr class="p2-row-net">
                        <td colspan="8">Net Payable Amount Rs.</td>
                        <td>${item.amount}</td>
                        <td></td>
                    </tr>
                    <tr class="p2-row-words">
                        <td></td>
                        <td colspan="8">Total Amount in words : ${item.amount}</td>
                        <td></td>
                    </tr>
                `;

                // clone.querySelector(".total").innerText = item.amount;

                // append full page
                container.appendChild(clone);
            });

        }

        window.onload = loadBill;

        function printBill() {
            window.print();
        }
    </script>

</div>
