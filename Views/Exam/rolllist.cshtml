@{
    ViewData["Title"] = "Roll List";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />
<div class="table-card">
    <div class="table-header">
        <h3 class="table-title">Roll List</h3>
        <div class="table-actions">
            <button class="btn btn-success mb-3" onclick="bulkPrintAllAdmitCards()">Bulk Print Admit Card</button>
        </div>
    </div>
    <div class="table-responsive">
        <table id="examTable" class="display custom-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Roll Number</th>
                    <th>Student Name</th>
                    <th>Student Email</th>
                    <th>Course</th>
                    <th>Semester</th>
                    <th>Exam</th>
                    <th style="text-align:center;">Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>
<script src="~/js/AdmitCard.js"></script>
<script>
    // ── IMPORTANT: must be on window so AdmitCard.js can read window._allApiRows ──
    window._allApiRows = [];

    $(document).ready(function () {
        $.ajax({
            url: ApiBaseUrl + 'Exam/rolllist',
            method: 'GET',
            success: function (data) {
                // Store ALL rows on window — AdmitCard.js reads window._allApiRows
                window._allApiRows = data;

                // ── Deduplicate for the TABLE only: one row per rollNumber ──────────
                var seen = {};
                var tableRows = [];
                data.forEach(function (r) {
                    if (!seen[r.rollNumber]) {
                        seen[r.rollNumber] = true;
                        tableRows.push(r);
                    }
                });

                // ── Init DataTable with deduplicated rows ─────────────────────────
                $('#examTable').DataTable({
                    data: tableRows,
                    columns: [
                        {
                            data: null,
                            render: (data, type, row, meta) =>
                                meta.row + meta.settings._iDisplayStart + 1
                        },
                        { data: 'rollNumber' },
                        { data: 'userName' },
                        { data: 'email' },
                        { data: 'courseName' },
                        { data: 'semesterName' },
                        { data: 'examName' },
                        {
                            data: null,
                            render: function (data) {
                                return `<button class="btn btn-edit"
                                            onclick='printRollAdmitCardByRoll("${data.rollNumber}")'>
                                            Print Admit Card
                                        </button>`;
                            }
                        }
                    ]
                });
            },
            error: function () {
                alert('Failed to load roll list.');
            }
        });
    });
</script>
