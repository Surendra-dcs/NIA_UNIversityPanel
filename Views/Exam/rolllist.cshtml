@{
    ViewData["Title"] = "Roll List";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />

<div class="table-card">
    <div class="table-header">
        <h3 class="table-title">Roll List</h3>
        <div class="table-actions">
            <button class="btn btn-success mb-3" onclick="openExamModal()">Bulk Print Admit Card</button>
        </div>
    </div>
    <div class="table-responsive">
        <table id="examTable" class="display custom-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Roll Number</th>
                    <th>Student Name</th>
                    <th>Student Email</th>
                    <th>Course</th>
                    <th>Semester</th>
                    <th>Exam</th>
                    <th style="text-align:center;">Action</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Include the shared admit card JS -->
<script src="~/js/AdmitCard.js"></script>

<script>

    $(document).ready(function () {
        $('#examTable').DataTable({
            ajax: {
                url: ApiBaseUrl + 'Exam/rolllist',
                dataSrc: ''
            },
            columns: [
                {
                    data: null,
                    render: (data, type, row, meta) =>
                        meta.row + meta.settings._iDisplayStart + 1
                },
                { data: 'rollNumber' },
                { data: 'userName' },
                { data: 'email' },
                { data: 'courseName' },
                { data: 'semesterName' },
                { data: 'examName' },
                {
                    data: null,
                    render: function (data) {
                        return `
                            <button class="btn btn-edit"
                                onclick='printRollAdmitCard(${JSON.stringify(data)})'>
                                Print Admit Card
                            </button>
                        `;
                    }
                }
            ]
        });
    });

    function openExamModal() {
        // Bulk print: iterate all loaded rows and open admit cards
        var dtInstance = $('#examTable').DataTable();
        var rows = dtInstance.rows().data().toArray();

        if (rows.length === 0) {
            alert('No data available to print.');
            return;
        }

        if (!confirm('This will open ' + rows.length + ' admit card(s) in new tabs. Make sure pop-ups are allowed. Continue?'))
            return;

        rows.forEach(function (row) {
            printRollAdmitCard(row);
        });
    }

</script>
