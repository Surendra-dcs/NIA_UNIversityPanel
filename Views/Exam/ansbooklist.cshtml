@{
    ViewData["Title"] = "Answer Book List";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />

<style>
    .filter-card {
        background: #f8f9fa;
        border-radius: 0.5rem;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
        border: 1px solid #e9ecef;
    }

    .filter-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        align-items: center;
    }

        .filter-row .form-control,
        .filter-row .form-select {
            border-radius: 0.375rem;
            border: 1px solid #dee2e6;
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }

            .filter-row .form-control:focus,
            .filter-row .form-select:focus {
                border-color: #86b7fe;
                box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
            }

        .filter-row .input-group {
            max-width: 300px;
        }

        .filter-row .input-group-text {
            background: #fff;
            border-right: none;
            border-radius: 0.375rem 0 0 0.375rem;
            color: #6c757d;
        }

        .filter-row .input-group .form-control {
            border-left: none;
            border-radius: 0 0.375rem 0.375rem 0;
        }

        .filter-row .form-select {
            max-width: 160px;
            cursor: pointer;
        }

    .btn-clear {
        background: #fff;
        border: 1px solid #dee2e6;
        color: #6c757d;
        border-radius: 0.375rem;
        padding: 0.5rem 0.875rem;
        font-size: 0.875rem;
        transition: all 0.15s ease-in-out;
        white-space: nowrap;
    }

        .btn-clear:hover {
            background: #e9ecef;
            color: #495057;
            border-color: #ced4da;
        }

    .badge-status {
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.35rem 0.65rem;
    }

    @@media (max-width: 576px) {
        .filter-row {
            flex-direction: column;
            align-items: stretch;
        }

            .filter-row .input-group,
            .filter-row .form-select {
                max-width: 100%;
            }
    }
</style>

<div class="table-card">
    <div class="table-header">
        <h3 class="table-title">Answer Book List</h3>
    </div>

    <!-- Filter Section -->
    <div class="filter-card">
        <div class="filter-row">
            <div class="input-group">
                <span class="input-group-text">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" id="searchInput" class="form-control"
                       placeholder="Search by student name or roll number...">
            </div>

            <select id="statusFilter" class="form-select">
                <option value="">📋 All Statuses</option>
                <option value="Pending">🕐 Pending</option>
                <option value="Evaluated">✅ Evaluated</option>
                <option value="Not Submitted">❌ Not Submitted</option>
            </select>

            <button class="btn-clear" id="clearFilters">
                <i class="bi bi-x-circle"></i> Clear Filters
            </button>
        </div>
    </div>

