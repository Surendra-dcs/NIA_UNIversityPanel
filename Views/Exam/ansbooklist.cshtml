<script>
    $(document).ready(function () {
        var table = $('#ansBookTable').DataTable({
            dom: 'rtip',
            order: [[0, 'asc']],
            language: {
                emptyTable: "No answer books found.",
                zeroRecords: "No records match your filter."
            }
        });

        // Custom search filter
        $.fn.dataTable.ext.search.push(function (settings, data) {
            if (settings.nTable.id !== 'ansBookTable') return true;

            var searchVal = $('#searchInput').val().trim().toLowerCase();
            var statusVal = $('#statusFilter').val().trim().toLowerCase();

            var rollNumber  = (data[1] ?? '').toLowerCase();
            var studentName = (data[2] ?? '').toLowerCase();
            var status      = (data[8] ?? '').toLowerCase();

            var matchSearch = !searchVal ||
                              rollNumber.includes(searchVal) ||
                              studentName.includes(searchVal);

            var plainStatus = status.replace(/<[^>]+>/g, '').trim().toLowerCase();
            var matchStatus = !statusVal || plainStatus.includes(statusVal);

            return matchSearch && matchStatus;
        });

        $('#searchInput').on('input', function () { table.draw(); });
        $('#statusFilter').on('change', function () { table.draw(); });

        $('#clearFilters').on('click', function () {
            $('#searchInput').val('');
            $('#statusFilter').val('');
            table.draw();
        });
    });
</script>