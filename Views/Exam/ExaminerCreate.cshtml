@{
    ViewData["Title"] = "Examiner Create";
    Layout = "~/Views/Shared/_UniversityLayout.cshtml";
}
<link href="~/css/programandcourse.css" rel="stylesheet" />

<style>
    .examiner-form {
        padding: 20px;
    }

    .form-section {
        margin-bottom: 25px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
    }

        .form-section h4 {
            margin-bottom: 15px;
            color: #333;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 6px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group.full-width {
            grid-column: span 3;
        }

    label {
        font-size: 14px;
        margin-bottom: 5px;
        color: #555;
    }

    input, textarea, select {
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 5px;
        font-size: 14px;
    }

    textarea {
        resize: vertical;
        min-height: 70px;
    }

        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #007bff;
        }

    .form-actions {
        margin-top: 20px;
    }

    .btn-primary {
        padding: 10px 20px;
        background-color: #2c7be5;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

        .btn-primary:hover {
            background-color: #1a5fd0;
        }

</style>

<div class="table-card">
    <div class="table-header">
        <h3 class="table-title">Create Examiner</h3>
    </div>

    <form class="examiner-form">

        <!-- Personal Info -->
        <div class="form-section">
            <h4>Personal Information</h4>
            <div class="form-grid">
                <div class="form-group">
                    <label>Name</label>
                    <input type="text" name="ExaminerName" />
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" name="Email" />
                </div>
                <div class="form-group">
                    <label>Mobile No</label>
                    <input type="text" name="MobileNo" />
                </div>
                <div class="form-group">
                    <label>PAN No</label>
                    <input type="text" name="PANNo" />
                </div>
            </div>
        </div>

        <!-- Academic Info -->
        <div class="form-section">
            <h4>Academic Details</h4>
            <div class="form-grid">
                <div class="form-group">
                    <label>Qualification</label>
                    <input type="text" name="Qualification" />
                </div>
                <div class="form-group">
                    <label>Specialization</label>
                    <input type="text" name="Specialization" />
                </div>
                <div class="form-group">
                    <label>Teaching Exp (UG)</label>
                    <input type="number" step="0.1" name="TeachingExpUG" />
                </div>
                <div class="form-group">
                    <label>Teaching Exp (PG)</label>
                    <input type="number" step="0.1" name="TeachingExpPG" />
                </div>
            </div>
        </div>

        <!-- College Info -->
        <div class="form-section">
            <h4>College Details</h4>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>College Name</label>
                    <input type="text" name="CollegeName" />
                </div>
                <div class="form-group full-width">
                    <label>College Address</label>
                    <textarea name="CollegeAddress"></textarea>
                </div>
                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="CollegeCity" />
                </div>
                <div class="form-group">
                    <label>District</label>
                    <input type="text" name="CollegeDistrict" />
                </div>
                <div class="form-group">
                    <label>State</label>
                    <input type="text" name="CollegeState" />
                </div>
                <div class="form-group">
                    <label>Pin Code</label>
                    <input type="text" name="CollegePinCode" />
                </div>
            </div>
        </div>

        <!-- Residential Info -->
        <div class="form-section">
            <h4>Residential Details</h4>
            <div class="form-grid">
                <div class="form-group full-width">
                    <label>Address</label>
                    <textarea name="ResidentialAddress"></textarea>
                </div>
                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="ResidentialCity" />
                </div>
                <div class="form-group">
                    <label>District</label>
                    <input type="text" name="ResidentialDistrict" />
                </div>
                <div class="form-group">
                    <label>State</label>
                    <input type="text" name="ResidentialState" />
                </div>
                <div class="form-group">
                    <label>Pin Code</label>
                    <input type="text" name="ResidentialPinCode" />
                </div>
            </div>
        </div>

        <!-- Bank Info -->
        <div class="form-section">
            <h4>Bank Details</h4>
            <div class="form-grid">
                <div class="form-group">
                    <label>Bank Name</label>
                    <input type="text" name="BankName" />
                </div>
                <div class="form-group">
                    <label>Account No</label>
                    <input type="text" name="BankAccountNo" />
                </div>
                <div class="form-group">
                    <label>IFSC Code</label>
                    <input type="text" name="IFSCCode" />
                </div>
            </div>
        </div>

        <!-- Submit -->
        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Examiner</button>
        </div>

    </form>
</div>

<script>
    $("form.examiner-form").submit(function (e) {
        e.preventDefault();

        let formData = {};

        $(this).find("input[name], textarea[name], select[name]").each(function () {
            formData[$(this).attr("name")] = $(this).val();
        });

        console.log("Sending:", formData);

        $.ajax({
            url: ApiBaseUrl + 'Examiner/Save',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(formData),

            success: function (res) {
                if (res.success) {
                    alert("Saved Successfully!");
                    window.location.href = '/Exam/ExaminerList';
                }
            },

            error: function () {
                alert("Error occurred");
            }
        });
    });
</script>

<script>
    $(document).ready(function () {

        const params = new URLSearchParams(window.location.search);
        const id = params.get("id");

        if (id) {
            loadExaminer(id);
        }
    });

        function loadExaminer(id) {
        $.get(ApiBaseUrl + 'Examiner/GetExaminer/' + id, function (data) {

            $('.table-title').text("Edit Examiner");
            $('.btn-primary').text("Update Examiner");

            console.log("DATA:", data);

            // map manually (safe way)
            $('[name="ExaminerName"]').val(data.examinerName);
            $('[name="Email"]').val(data.email);
            $('[name="MobileNo"]').val(data.mobileNo);
            $('[name="PANNo"]').val(data.panNo);

            $('[name="Qualification"]').val(data.qualification);
            $('[name="Specialization"]').val(data.specialization);
            $('[name="TeachingExpUG"]').val(data.teachingExpUG);
            $('[name="TeachingExpPG"]').val(data.teachingExpPG);

            $('[name="CollegeName"]').val(data.collegeName);
            $('[name="CollegeAddress"]').val(data.collegeAddress);
            $('[name="CollegeCity"]').val(data.collegeCity);
            $('[name="CollegeDistrict"]').val(data.collegeDistrict);
            $('[name="CollegeState"]').val(data.collegeState);
            $('[name="CollegePinCode"]').val(data.collegePinCode);

            $('[name="ResidentialAddress"]').val(data.residentialAddress);
            $('[name="ResidentialCity"]').val(data.residentialCity);
            $('[name="ResidentialDistrict"]').val(data.residentialDistrict);
            $('[name="ResidentialState"]').val(data.residentialState);
            $('[name="ResidentialPinCode"]').val(data.residentialPinCode);

            $('[name="BankName"]').val(data.bankName);
            $('[name="BankAccountNo"]').val(data.bankAccountNo);
            $('[name="IFSCCode"]').val(data.ifscCode);

            // IMPORTANT: set hidden ID
            if (!$("#ExaminerID").length) {
                $("form").append(`<input type="hidden" name="ExaminerID" value="${data.examinerID}" />`);
            }
        });
    }
</script>